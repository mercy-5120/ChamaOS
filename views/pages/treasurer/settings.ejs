<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — Treasurer Settings</title>
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="/css/treasurer.css" />
  </head>
  <body>
    <main class="container dashboard-layout">
      <%- include('../partials/treasurersidebar') %>

      <section class="dashboard-content">
        <div class="page-header">
          <div>
            <h1 class="h1">Settings</h1>
            <p class="lead">
              Manage contribution amounts, interest rates and limits.
            </p>
          </div>
        </div>

        <% if (success) { %>
          <div class="alert alert-success"><%= success %></div>
        <% } %>
        <% if (error) { %>
          <div class="alert alert-error"><%= error %></div>
        <% } %>

        <section class="dashboard-section">
          <h2 class="h2">Financial Settings</h2>
          <div class="card">
            <form method="POST" action="/treasurer/settings">
              <div class="form-grid">
                <div class="form-group">
                  <label>Monthly Contribution (KES)</label>
                  <input
                    type="number"
                    name="contribution_amount"
                    min="1"
                    step="0.01"
                    value="<%= Number(settings?.contribution_amount || 0) %>"
                    required
                  />
                </div>
                <div class="form-group">
                  <label>Contribution Due Day</label>
                  <input type="text" value="5th of every month" readonly />
                </div>
                <div class="form-group">
                  <label>Next Due Date</label>
                  <input type="text" value="<%= nextDueDate || '-' %>" readonly />
                </div>
              </div>

              <p class="text-muted" style="margin-top: 12px; font-size: 13px">
                Rule: once the date reaches the 5th, the due date automatically rolls to the 5th of the next month.
              </p>

              <div style="margin-top: 16px">
                <button class="btn btn-primary">Save Settings</button>
              </div>
            </form>
          </div>
        </section>
      </section>
    </main>
  </body>
</html>
