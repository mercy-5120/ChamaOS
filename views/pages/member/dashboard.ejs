<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — Member Dashboard</title>
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="/css/member.css" />
  </head>
  <body>
    <main class="container dashboard-layout">
      <%- include('../partials/membersidebar') %>

      <section class="dashboard-content">
        <div class="page-header">
          <div>
            <h1 class="h1">Dashboard</h1>
            <p class="lead">Welcome back! Here's your chama overview.</p>
          </div>
        </div>

        <!-- CONTRIBUTION SUMMARY -->
        <section class="dashboard-section">
          <h2 class="h2">Contribution Summary</h2>
          <div class="metrics-grid">
            <div class="metric-card">
              <div class="metric-label">Total Contributed</div>
              <div class="metric-value value-deep">
                KES <%= Number(contributionSummary?.total_contributed || 0).toLocaleString() %>
              </div>
              <div class="small" style="margin-top: 8px">
                <%= contributionSummary?.transaction_count || 0 %> recorded payments
              </div>
            </div>

            <div class="metric-card">
              <div class="metric-label">Last Payment</div>
              <div class="metric-value value-success"><%= contributionSummary?.last_payment || '-' %></div>
              <div class="small" style="margin-top: 8px">Date payment was made</div>
            </div>

            <div class="metric-card">
              <div class="metric-label">Next Due Date</div>
              <div class="metric-value value-warning">-</div>
              <div class="small" style="margin-top: 8px">No data yet</div>
            </div>
          </div>
        </section>

        <!-- LOAN STATUS -->
        <section class="dashboard-section">
          <h2 class="h2">Active Loans</h2>
          <div class="card">
            <table class="table">
              <thead>
                <tr>
                  <th>Loan ID</th>
                  <th>Amount Borrowed</th>
                  <th>Amount Repaid</th>
                  <th>Balance</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% if (activeLoans && activeLoans.length > 0) { %>
                  <% activeLoans.forEach(function(loan) { %>
                    <tr>
                      <td><%= loan.loan_id %></td>
                      <td>KES <%= Number(loan.amount).toLocaleString() %></td>
                      <td>KES <%= Number(loan.amount - loan.remaining_balance).toLocaleString() %></td>
                      <td>KES <%= Number(loan.remaining_balance).toLocaleString() %></td>
                      <td><span class="badge badge-success">Active</span></td>
                    </tr>
                  <% }); %>
                <% } else { %>
                  <tr>
                    <td colspan="5">No active loans available.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
            <div style="margin-top: 15px">
              <a href="/member/loans" class="btn btn-primary">Manage Loans</a>
            </div>
          </div>
        </section>

        <!-- ANNOUNCEMENTS -->
        <section class="dashboard-section">
          <h2 class="h2">Recent Announcements</h2>
          <div class="card announcement-box">
            <% if (announcements && announcements.length > 0) { %>
              <% announcements.forEach(function(ann) { %>
                <div class="announcement-item priority-<%= ann.priority %>">
                  <div class="announcement-meta">
                    <span class="announcement-title"><%= ann.title %></span>
                    <span class="announcement-badge badge-<%= ann.priority %>"><%= ann.priority %></span>
                  </div>
                  <p class="announcement-content"><%= ann.content %></p>
                  <div class="announcement-footer">
                    <span>Posted by <%= ann.posted_by %></span>
                    <span><%= ann.created_at %></span>
                  </div>
                </div>
              <% }); %>
            <% } else { %>
              <p>No announcements available.</p>
            <% } %>
          </div>
        </section>

        <!-- UPCOMING MEETINGS -->
        <section class="dashboard-section">
          <h2 class="h2">Upcoming Meetings</h2>
          <div class="card">
            <div class="meeting-list">
              <p>No upcoming meetings available.</p>
            </div>
            <div style="margin-top: 15px">
              <a href="/member/meetings" class="btn btn-primary"
                >View All Meetings</a
              >
            </div>
          </div>
        </section>

        <div style="margin-top: 30px; padding-bottom: 30px">
          <a href="/member/contributions" class="btn btn-secondary"
            >View Contributions</a
          >
          <a href="/member/group" class="btn btn-secondary">View Group Info</a>
        </div>
      </section>
    </main>
  </body>
</html>
