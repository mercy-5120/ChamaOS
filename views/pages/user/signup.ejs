<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — Create a New Chama</title>
    <link rel="stylesheet" href="/css/app.css" />

    <style></style>
  </head>
  <body>
    <%- include('../partials/header', { brandTagline: 'Collective savings. Built together.', navItems: [ { text: 'Home', href: '/' }, { text: 'Login', href: '/login' }, { text: 'Create Chama', href: '/signup', cta: true } ] }) %>

    <main class="container">
      <section class="auth-wrap">
        <div class="card auth-card">
          <h3 class="h1">Create a New Chama</h3>
          <p class="lead">
            Set up your savings group and create your chairperson account.
          </p>

          <% if (typeof error !== 'undefined' && error) { %>
            <p class="error-message" role="alert"><%= error %></p>
          <% } %>

          <form action="/signup" method="POST" autocomplete="on">
            <div class="form-grid">

              <div>
                <label for="chama_name">Chama Name *</label>
                <input
                  id="chama_name"
                  name="chama_name"
                  type="text"
                  required
                  maxlength="50"
                  placeholder="e.g., Umoja Savings Group"
                  value="<%= formData?.chama_name || '' %>"
                />
              </div>

              <div>
                <label for="invite_code">Invite Code *</label>
                <input
                  id="invite_code"
                  name="invite_code"
                  type="text"
                  required
                  maxlength="20"
                  placeholder="e.g., UMOJA2026"
                  value="<%= formData?.invite_code || '' %>"
                />
                <small class="muted-note">Members will use this code to join your Chama.</small>
              </div>

              <div>
                <label for="description">Description</label>
                <textarea
                  id="description"
                  name="description"
                  rows="3"
                  placeholder="Briefly describe the purpose or goals of this Chama..."
                ><%= formData?.description || '' %></textarea>
              </div>

              <div>
                <label for="meeting_day">Meeting Day *</label>
                <select id="meeting_day" name="meeting_day" required>
                  <option value="">Select a day...</option>
                  <option value="Monday" <%= formData?.meeting_day === 'Monday' ? 'selected' : '' %>>Monday</option>
                  <option value="Tuesday" <%= formData?.meeting_day === 'Tuesday' ? 'selected' : '' %>>Tuesday</option>
                  <option value="Wednesday" <%= formData?.meeting_day === 'Wednesday' ? 'selected' : '' %>>Wednesday</option>
                  <option value="Thursday" <%= formData?.meeting_day === 'Thursday' ? 'selected' : '' %>>Thursday</option>
                  <option value="Friday" <%= formData?.meeting_day === 'Friday' ? 'selected' : '' %>>Friday</option>
                  <option value="Saturday" <%= formData?.meeting_day === 'Saturday' ? 'selected' : '' %>>Saturday</option>
                  <option value="Sunday" <%= formData?.meeting_day === 'Sunday' ? 'selected' : '' %>>Sunday</option>
                </select>
              </div>

              <div class="form-row">
                <div class="form-col">
                  <label for="contribution_amount">Contribution Amount *</label>
                  <input
                    id="contribution_amount"
                    name="contribution_amount"
                    type="number"
                    required
                    min="1"
                    step="0.01"
                    placeholder="e.g., 500"
                    value="<%= formData?.contribution_amount || '' %>"
                  />
                </div>
                <div class="form-col">
                  <label for="currency">Currency *</label>
                  <select id="currency" name="currency" required>
                    <option value="">Select...</option>
                    <option value="KES" <%= formData?.currency === 'KES' ? 'selected' : '' %>>KES — Kenyan Shilling</option>
                    <option value="UGX" <%= formData?.currency === 'UGX' ? 'selected' : '' %>>UGX — Ugandan Shilling</option>
                    <option value="TZS" <%= formData?.currency === 'TZS' ? 'selected' : '' %>>TZS — Tanzanian Shilling</option>
                    <option value="USD" <%= formData?.currency === 'USD' ? 'selected' : '' %>>USD — US Dollar</option>
                    <option value="GBP" <%= formData?.currency === 'GBP' ? 'selected' : '' %>>GBP — British Pound</option>
                    <option value="EUR" <%= formData?.currency === 'EUR' ? 'selected' : '' %>>EUR — Euro</option>
                  </select>
                </div>
              </div>

            </div>

            <hr style="margin:1.5rem 0;border:none;border-top:1px solid #e0e0e0;">
            <h4 style="margin-bottom:0.75rem;">Your Chairperson Account</h4>
            <div class="form-grid">

              <div class="form-row">
                <div class="form-col">
                  <label for="chair_fullname">Full Name *</label>
                  <input
                    id="chair_fullname"
                    name="chair_fullname"
                    type="text"
                    required
                    maxlength="100"
                    placeholder="e.g., Jane Doe"
                    value="<%= formData?.chair_fullname || '' %>"
                  />
                </div>
                <div class="form-col">
                  <label for="chair_phone">Phone Number *</label>
                  <input
                    id="chair_phone"
                    name="chair_phone"
                    type="tel"
                    required
                    maxlength="15"
                    placeholder="e.g., +254 700 000 000"
                    value="<%= formData?.chair_phone || '' %>"
                  />
                </div>
              </div>

              <div>
                <label for="chair_email">Email Address *</label>
                <input
                  id="chair_email"
                  name="chair_email"
                  type="email"
                  required
                  placeholder="e.g., jane@example.com"
                  value="<%= formData?.chair_email || '' %>"
                />
              </div>

              <div>
                <label for="chair_password">Password *</label>
                <input
                  id="chair_password"
                  name="chair_password"
                  type="password"
                  required
                  placeholder="Create a strong password"
                />
              </div>

              <div>
                <label for="chair_role">Role</label>
                <input
                  id="chair_role"
                  name="chair_role"
                  type="text"
                  value="chairperson"
                  readonly
                />
                <small class="muted-note">Default role for this account in your Chama.</small>
              </div>

            </div>

            <div class="checkbox-wrapper">
              <input type="checkbox" id="agree" class="muted-note" required>
              <label for="agree">By creating a Chama you agree to our community guidelines and
                commit to upholding the group's values.</label>
            </div>

            <div class="form-foot">
              <div class="helper">
                Already have a Chama?
                <a href="/login" class="link-muted">Login</a>
                &nbsp;|&nbsp;
                Have an invite code?
                <a href="/join" class="link-muted">Join a Chama</a>
              </div>
              <button class="btn btn-primary" type="submit">
                Create Chama
              </button>
            </div>
          </form>
        </div>

         </section>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
