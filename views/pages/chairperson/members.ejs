<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — Chairperson Member Oversight</title>
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="/css/chairperson.css" />
    <style>
      .oversight-summary { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.25rem; margin-bottom: 2rem; }
      .oversight-stat-card { background: #fff; border-radius: 10px; border-left: 4px solid #7b9cdf; padding: 1.5rem; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06); }
      .oversight-stat-card.pending { border-left-color: #f39c12; }
      .oversight-stat-card.discipline { border-left-color: #e74c3c; }
      .oversight-stat-label { font-size: 0.85rem; color: #6c757d; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 0.5rem; }
      .oversight-stat-value { font-size: 2.5rem; font-weight: 700; color: #2c3e50; }
      .oversight-stat-sub { font-size: 0.9rem; color: #95a5a6; margin-top: 0.25rem; }
      .invite-showcase { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border-radius: 10px; padding: 2rem; margin-bottom: 2rem; display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
      .invite-code-display { font-size: 1.75rem; font-weight: 700; letter-spacing: 0.2em; background: rgba(255, 255, 255, 0.15); padding: 1rem 1.5rem; border-radius: 8px; font-family: 'Courier New', monospace; }
      .invite-description { flex: 1; min-width: 250px; }
      .invite-description p { margin: 0; font-size: 0.95rem; opacity: 0.95; }
      .button-group { display: flex; gap: 0.75rem; flex-wrap: wrap; }
      .btn-copy { background: rgba(255, 255, 255, 0.25); color: white; border: 1px solid rgba(255, 255, 255, 0.4); padding: 0.625rem 1.25rem; border-radius: 6px; font-weight: 500; cursor: pointer; transition: all 0.3s ease; }
      .btn-copy:hover { background: rgba(255, 255, 255, 0.35); }
      .form-section { background: white; border-radius: 10px; padding: 1.75rem; margin-bottom: 2rem; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06); }
      .form-section h3 { margin-top: 0; margin-bottom: 1.5rem; color: #2c3e50; font-size: 1.1rem; }
      .form-grid-2col { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; margin-bottom: 1.5rem; }
      .table-wrapper { background: white; border-radius: 10px; overflow: hidden; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06); }
      .table-section { margin-bottom: 2rem; }
      .table-title { font-size: 1.15rem; font-weight: 600; color: #2c3e50; margin-bottom: 1rem; padding: 0 0.25rem; }
      .table { width: 100%; border-collapse: collapse; }
      .table thead { background: #f8f9fa; }
      .table th { padding: 1rem 1.25rem; text-align: left; font-weight: 600; color: #495057; font-size: 0.9rem; border-bottom: 2px solid #e9ecef; }
      .table td { padding: 0.875rem 1.25rem; border-bottom: 1px solid #e9ecef; }
      .table tbody tr:hover { background: #f8f9fa; }
      .table tbody tr:last-child td { border-bottom: none; }
      .badge { display: inline-block; padding: 0.375rem 0.75rem; border-radius: 20px; font-size: 0.8rem; font-weight: 600; }
      .badge-info { background: #ecf0f1; color: #34495e; }
      .badge-pending { background: #fff3cd; color: #856404; }
      .badge-warning { background: #f8d7da; color: #721c24; }
      .no-data { text-align: center; padding: 2.5rem 1rem; color: #7f8c8d; }
      .no-data-icon { font-size: 2rem; margin-bottom: 0.5rem; opacity: 0.5; }
    </style>
  </head>
  <body>
    <main class="container dashboard-layout">
      <%- include('../partials/chairpersonsidebar') %>

      <section class="dashboard-content">
        <div class="page-header">
          <div>
            <h1 class="h1">Member Oversight</h1>
            <p class="lead">
              Manage member access, review join requests, and maintain disciplinary records.
            </p>
          </div>
        </div>

        <!-- Flash messages -->
        <% if (typeof success !== 'undefined' && success) { %>
          <div style="color:#1a7a3c;background:#eafaf1;border:1px solid #27ae60;border-radius:6px;padding:0.75rem 1rem;margin-bottom:1rem;">
            <%= success %>
          </div>
        <% } %>
        <% if (typeof error !== 'undefined' && error) { %>
          <div style="color:#c0392b;background:#fdecea;border:1px solid #e74c3c;border-radius:6px;padding:0.75rem 1rem;margin-bottom:1rem;">
            <%= error %>
          </div>
        <% } %>

        <!-- Summary Statistics -->
        <div class="oversight-summary">
          <div class="oversight-stat-card">
            <div class="oversight-stat-label">Total Members</div>
            <div class="oversight-stat-value"><%= members ? members.length : 0 %></div>
            <div class="oversight-stat-sub">Active in chama</div>
          </div>
          <div class="oversight-stat-card discipline">
            <div class="oversight-stat-label">Disciplinary Records</div>
            <div class="oversight-stat-value"><%= disciplinaryRecords ? disciplinaryRecords.length : 0 %></div>
            <div class="oversight-stat-sub">Active records</div>
          </div>
        </div>

        <!-- Chama Invite Code -->
        <div class="invite-showcase">
          <div class="invite-description">
            <p><strong>Invite New Members</strong></p>
            <p>Share this code with anyone you want to invite to <strong><%= chama.chama_name %></strong>. They can use it during signup to join your chama instantly.</p>
          </div>
          <div style="display:flex;flex-direction:column;align-items:center;gap:0.75rem;">
            <div class="invite-code-display"><%= chama.invite_code %></div>
            <button class="btn-copy" onclick="navigator.clipboard.writeText('<%= chama.invite_code %>').then(()=>alert('Invite code copied to clipboard!'))">
               Copy Code
            </button>
          </div>
        </div>

        <!-- Add New Member Form -->
        <div class="form-section">
          <h3>Add New Member</h3>
          <form action="/chairperson/add-member" method="POST" autocomplete="off">
            <div class="form-grid-2col">
              <div>
                <label for="full_name">Full Name *</label>
                <input id="full_name" name="full_name" type="text" required maxlength="100" placeholder="e.g., Alice Wanjiru" />
              </div>
              <div>
                <label for="phone_number">Phone Number *</label>
                <input id="phone_number" name="phone_number" type="tel" required maxlength="15" placeholder="e.g., +254 700 000 000" />
              </div>
              <div>
                <label for="email">Email Address</label>
                <input id="email" name="email" type="email" placeholder="e.g., alice@example.com" />
              </div>
              <div>
                <label for="role">Role *</label>
                <select id="role" name="role" required>
                  <option value="">Select a role...</option>
                  <option value="member">Member</option>
                  <option value="treasurer">Treasurer</option>
                  <option value="secretary">Secretary</option>
                  <option value="chairperson">Chairperson</option>
                </select>
              </div>
            </div>
            <div>
              <label for="password">Temporary Password *</label>
              <input id="password" name="password" type="password" required placeholder="Set a temporary password" />
              <small class="muted-note" style="display:block;margin-top:0.25rem;">The member should change this after their first login.</small>
            </div>
            <div style="margin-top:1.5rem;text-align:right;">
              <button class="btn btn-primary" type="submit">Add Member</button>
            </div>
          </form>
        </div>

        <!-- Active Members Table -->
        <div class="table-section">
          <div class="table-title">Active Members</div>
          <div class="table-wrapper">
            <table class="table">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Phone</th>
                  <th>Email</th>
                  <th>Role</th>
                  <th>Joined Date</th>
                </tr>
              </thead>
              <tbody>
                <% if (members && members.length > 0) { %>
                  <% members.forEach(function(m) { %>
                    <tr>
                      <td style="font-weight:500;"><%= m.full_name %></td>
                      <td><%= m.phone_number %></td>
                      <td><%= m.email || '—' %></td>
                      <td><span class="badge badge-info" style="text-transform:capitalize;"><%= m.role %></span></td>
                      <td><%= m.joined_date ? new Date(m.joined_date).toLocaleDateString() : '—' %></td>
                    </tr>
                  <% }); %>
                <% } else { %>
                  <tr>
                    <td colspan="5" class="no-data">
                      <p>No active members yet.</p>
                    </td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Disciplinary Records -->
        <div class="table-section">
          <div class="table-title">Disciplinary Records</div>
          <div class="table-wrapper">
            <table class="table">
              <thead>
                <tr>
                  <th>Reported Member</th>
                  <th>Reported By</th>
                  <th>Issue</th>
                  <th>Reported On</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% if (disciplinaryRecords && disciplinaryRecords.length > 0) { %>
                  <% disciplinaryRecords.forEach(function(record) { %>
                    <tr>
                      <td><%= record.reported_member_name || '-' %></td>
                      <td><%= record.reported_by_name || '-' %></td>
                      <td>
                        <strong><%= record.subject %></strong>
                        <div style="font-size:12px;color:#7f8c8d;margin-top:2px;"><%= record.description %></div>
                      </td>
                      <td><%= record.created_at || '-' %></td>
                      <td style="text-transform: capitalize;"><%= record.status || 'open' %></td>
                    </tr>
                  <% }); %>
                <% } else { %>
                  <tr>
                    <td colspan="5" class="no-data">
                      <p>No disciplinary records.</p>
                    </td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>
