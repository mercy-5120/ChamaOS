<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — Members (Treasurer)</title>
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="/css/treasurer.css" />
  </head>
  <body>
    <main class="container dashboard-layout">
      <%- include('../partials/treasurersidebar') %>

      <section class="dashboard-content">
        <div class="page-header">
          <div>
            <h1 class="h1">Members</h1>
            <p class="lead">
              Individual statements, contribution & loan history.
            </p>
          </div>
        </div>

        <section class="dashboard-section">
          <h2 class="h2">Member Directory</h2>
          <div class="card">
            <table class="table">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Role</th>
                  <th>Phone</th>
                  <th>Email</th>
                  <th>Member Since</th>
                </tr>
              </thead>
              <tbody>
                <% if (members && members.length > 0) { %>
                  <% members.forEach((member) => { %>
                    <tr>
                      <td><%= member.full_name %></td>
                      <td><%= member.role || 'member' %></td>
                      <td><%= member.phone_number || '-' %></td>
                      <td><%= member.email || '-' %></td>
                      <td><%= member.joined_date || '-' %></td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="5">No members available.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </section>
      </section>
    </main>
  </body>
</html>
