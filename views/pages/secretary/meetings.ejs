<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — Meeting Management</title>
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="/css/secretary.css" />
  </head>
  <body>
    <main class="container dashboard-layout">
      <%- include('../partials/secretarysidebar') %>

      <section class="dashboard-content">
        <div class="page-header">
          <div>
            <h1 class="h1">Meeting Management</h1>
            <p class="lead">
              Create, record, and track all group meetings and action items.
            </p>
          </div>
          <div>
            <button class="btn btn-primary" data-action="create-meeting">
              + New Meeting
            </button>
          </div>
        </div>

        <% if (success) { %>
          <div class="alert alert-success"><%= success %></div>
        <% } %>
        <% if (error) { %>
          <div class="alert alert-error"><%= error %></div>
        <% } %>

        <!-- Create New Meeting Section -->
        <section class="dashboard-section">
          <h2 class="h2">Create New Meeting Record</h2>
          <div class="card form-card">
            <form class="form-group" method="POST" action="/secretary/meetings/create">
              <div class="form-row">
                <div class="form-col">
                  <label for="meeting-title" class="form-label"
                    >Meeting Title *</label
                  >
                  <input
                    type="text"
                    id="meeting-title"
                    name="meeting_title"
                    class="form-control"
                    placeholder="e.g., Monthly General Meeting"
                    required
                  />
                </div>
                <div class="form-col">
                  <label for="meeting-date" class="form-label"
                    >Meeting Date *</label
                  >
                  <input
                    type="date"
                    id="meeting-date"
                    name="meeting_date"
                    class="form-control"
                    required
                  />
                </div>
              </div>

              <div class="form-row">
                <div class="form-col">
                  <label for="meeting-time" class="form-label"
                    >Meeting Time *</label
                  >
                  <input
                    type="time"
                    id="meeting-time"
                    name="meeting_time"
                    class="form-control"
                    required
                  />
                </div>
                <div class="form-col">
                  <label for="meeting-location" class="form-label"
                    >Location *</label
                  >
                  <input
                    type="text"
                    id="meeting-location"
                    name="meeting_location"
                    class="form-control"
                    placeholder="e.g., Community Hall"
                    required
                  />
                </div>
              </div>

              <div class="form-row">
                <div class="form-col full-width">
                  <label for="meeting-agenda" class="form-label"
                    >Agenda *</label
                  >
                  <textarea
                    id="meeting-agenda"
                    name="meeting_agenda"
                    class="form-control"
                    rows="4"
                    placeholder="Enter meeting agenda items..."
                    required
                  ></textarea>
                </div>
              </div>

              <button type="submit" class="btn btn-primary">
                Create Meeting
              </button>
            </form>
          </div>
        </section>

        <!-- All Meetings -->
        <section class="dashboard-section">
          <h2 class="h2">All Meetings</h2>
          <div class="card">
            <table class="table">
              <thead>
                <tr>
                  <th>Meeting Title</th>
                  <th>Date & Time</th>
                  <th>Location</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% if (meetings && meetings.length > 0) { %>
                  <% meetings.forEach(function(meeting) { %>
                    <tr>
                      <td><%= meeting.meeting_title %></td>
                      <td><%= meeting.meeting_date %> <%= meeting.meeting_time || '' %></td>
                      <td><%= meeting.location %></td>
                      <td>
                        <% if (meeting.meeting_status === 'upcoming') { %>
                          <span class="badge badge-warning">Upcoming</span>
                        <% } else { %>
                          <span class="badge badge-success">Completed</span>
                        <% } %>
                      </td>
                      <td>
                        <a href="/secretary/meetings/<%= meeting.meeting_id %>" class="btn btn-secondary btn-sm">View</a>
                      </td>
                    </tr>
                  <% }); %>
                <% } else { %>
                  <tr>
                    <td colspan="5">No meeting records available.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </section>

        <!-- Record Meeting Minutes -->
        <section class="dashboard-section">
          <h2 class="h2">Record Meeting Minutes</h2>
          <div class="card form-card">
            <form class="form-group">
              <div class="form-row">
                <div class="form-col">
                  <label for="minute-meeting" class="form-label"
                    >Select Meeting *</label
                  >
                  <select id="minute-meeting" class="form-control" required>
                    <option value="">-- Select a meeting --</option>
                    <% if (meetings && meetings.length > 0) { %>
                      <% meetings.forEach(function(meeting) { %>
                        <option value="<%= meeting.meeting_id %>">
                          <%= meeting.meeting_title || ('Meeting #' + meeting.meeting_id) %>
                          - <%= meeting.meeting_date %>
                          <%= meeting.meeting_time ? (' ' + meeting.meeting_time) : '' %>
                        </option>
                      <% }); %>
                    <% } %>
                  </select>
                </div>
              </div>

              <div class="form-row">
                <div class="form-col full-width">
                  <label for="meeting-minutes" class="form-label"
                    >Meeting Minutes (Rich Text) *</label
                  >
                  <textarea
                    id="meeting-minutes"
                    class="form-control rich-editor"
                    rows="8"
                    placeholder="Record detailed meeting minutes..."
                    required
                  ></textarea>
                  <p class="text-muted text-sm">
                    Supports: Bold, Italics, Lists, Links
                  </p>
                </div>
              </div>

              <div class="form-row">
                <div class="form-col full-width">
                  <label for="meeting-decisions" class="form-label"
                    >Decisions Made</label
                  >
                  <textarea
                    id="meeting-decisions"
                    class="form-control"
                    rows="4"
                    placeholder="List key decisions..."
                  ></textarea>
                </div>
              </div>

              <button type="submit" class="btn btn-primary">
                Save Minutes
              </button>
            </form>
          </div>
        </section>

        <!-- Mark Attendance -->
        <section class="dashboard-section">
          <h2 class="h2">Mark Attendance</h2>
          <div class="card form-card">
            <form class="form-group" method="POST" action="/secretary/meetings/attendance">
              <div class="form-row">
                <div class="form-col">
                  <label for="attend-meeting" class="form-label"
                    >Select Meeting *</label
                  >
                  <select id="attend-meeting" name="meeting_id" class="form-control" required>
                    <option value="">-- Select a meeting --</option>
                    <% if (meetings && meetings.length > 0) { %>
                      <% meetings.forEach(function(meeting) { %>
                        <option value="<%= meeting.meeting_id %>">
                          <%= meeting.meeting_title || ('Meeting #' + meeting.meeting_id) %>
                          - <%= meeting.meeting_date %>
                          <%= meeting.meeting_time ? (' ' + meeting.meeting_time) : '' %>
                        </option>
                      <% }); %>
                    <% } %>
                  </select>
                </div>
              </div>

              <div class="attendance-grid">
                <h3 class="h3">Select Members Present</h3>
                <p class="text-muted" style="margin-bottom: 10px; font-size: 13px;">
                  Selected Present: <strong id="present-count">0</strong>
                  | Selected Absent: <strong id="absent-count"><%= members ? members.length : 0 %></strong>
                </p>
                <div class="member-checklist">
                  <% if (members && members.length > 0) { %>
                    <% members.forEach(function(member) { %>
                      <label class="checkbox-item" style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
                        <input type="checkbox" class="attendance-checkbox" name="present_members" value="<%= member.user_id %>" />
                        <span>
                          <%= member.full_name %>
                          <% if (member.role && member.role !== 'member') { %>
                            (<%= member.role %>)
                          <% } %>
                        </span>
                      </label>
                    <% }); %>
                  <% } else { %>
                    <p>No members available.</p>
                  <% } %>
                </div>
              </div>

              <button type="submit" class="btn btn-primary">
                Save Attendance
              </button>
            </form>
          </div>
        </section>

        <!-- Upload Meeting Attachments -->
        <section class="dashboard-section">
          <h2 class="h2">Upload Meeting Attachments</h2>
          <div class="card form-card">
            <form
              class="form-group"
              method="POST"
              action="/secretary/meetings/attachments"
              enctype="multipart/form-data"
            >
              <div class="form-row">
                <div class="form-col">
                  <label for="attach-meeting" class="form-label"
                    >Select Meeting *</label
                  >
                  <select
                    id="attach-meeting"
                    name="meeting_id"
                    class="form-control"
                    required
                  >
                    <option value="">-- Select a meeting --</option>
                    <% if (meetings && meetings.length > 0) { %>
                      <% meetings.forEach(function(meeting) { %>
                        <option value="<%= meeting.meeting_id %>">
                          <%= meeting.meeting_title || ('Meeting #' + meeting.meeting_id) %>
                          - <%= meeting.meeting_date %>
                          <%= meeting.meeting_time ? (' ' + meeting.meeting_time) : '' %>
                        </option>
                      <% }); %>
                    <% } %>
                  </select>
                </div>
              </div>

              <div class="form-row">
                <div class="form-col full-width">
                  <label for="attachments" class="form-label"
                    >Upload Documents/Spreadsheets</label
                  >
                  <div class="file-upload">
                    <input
                      type="file"
                      id="attachments"
                      name="attachments"
                      class="form-control"
                      multiple
                      accept=".pdf,.doc,.docx,.xls,.xlsx"
                    />
                    <p class="text-muted text-sm">
                      Accepted: PDF, Word, Excel documents
                    </p>
                  </div>
                </div>
              </div>

              <button type="submit" class="btn btn-primary">
                Upload Attachments
              </button>
            </form>
          </div>
        </section>
      </section>
    </main>

    <script>
      (function () {
        const checkboxes = document.querySelectorAll(".attendance-checkbox");
        const presentCountEl = document.getElementById("present-count");
        const absentCountEl = document.getElementById("absent-count");

        if (!checkboxes.length || !presentCountEl || !absentCountEl) {
          return;
        }

        const totalMembers = checkboxes.length;

        const refreshCounts = function () {
          let present = 0;
          checkboxes.forEach(function (checkbox) {
            if (checkbox.checked) present += 1;
          });
          presentCountEl.textContent = String(present);
          absentCountEl.textContent = String(totalMembers - present);
        };

        checkboxes.forEach(function (checkbox) {
          checkbox.addEventListener("change", refreshCounts);
        });

        refreshCounts();
      })();
    </script>
  </body>
</html>
