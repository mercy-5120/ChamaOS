<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — Services & Features</title>
    <link rel="stylesheet" href="/css/app.css" />
  </head>
  <body>
    <%- include('../partials/header', { brandTagline: 'Community savings. Built together.', navItems: [ { text: 'Home', href: '/' }, { text: 'Login', href: '/login' }, { text: 'Get started', href: '/signup', cta: true } ] }) %>

    <main class="container">
      <section class="page-header">
        <h1 class="page-title">All services & features</h1>
        <p class="page-subtitle">
          Everything you need to manage group savings, track contributions and
          celebrate shared milestones — all in one warm, trustworthy platform.
        </p>
      </section>

      <!-- Group & Member Management -->
      <section class="service-section card" style="padding: 28px">
        <div class="section-header">
          <div class="section-icon">👥</div>
          <div>
            <h2 class="section-title">Group & Member Management</h2>
            <p class="section-desc">
              Create, organize and manage your chamas with flexible roles and
              permissions.
            </p>
          </div>
        </div>

        <div class="feature-grid" style="margin-top: 18px">
          <div class="feature-card">
            <h4>Create chamas</h4>
            <p>
              Start a new group in seconds with a name, description and member
              list. Define your group's purpose and culture.
            </p>
          </div>
          <div class="feature-card">
            <h4>Invite members</h4>
            <p>
              Send invitations to group members via email or phone. Track
              acceptance and send reminders to pending invites.
            </p>
          </div>
          <div class="feature-card">
            <h4>Set rules & schedules</h4>
            <p>
              Define contribution amounts, payment frequency and group rules.
              Make expectations clear from day one.
            </p>
          </div>
          <div class="feature-card">
            <h4>Assign roles</h4>
            <p>
              Create admins, treasurers, members and auditors. Each role has
              clear permissions and responsibilities.
            </p>
          </div>
          <div class="feature-card">
            <h4>Member profiles</h4>
            <p>
              Track member info, contribution history, status and activity.
              Build transparency and trust in your group.
            </p>
          </div>
          <div class="feature-card">
            <h4>Approval workflows</h4>
            <p>
              Set how decisions are made. Require admin approval for new
              members, rule changes or payouts.
            </p>
          </div>
        </div>
      </section>

      <!-- Contribution & Payment Tracking -->
      <section class="service-section card" style="padding: 28px">
        <div class="section-header">
          <div class="section-icon">📝</div>
          <div>
            <h2 class="section-title">Contribution & Payment Tracking</h2>
            <p class="section-desc">
              Automatic reminders, digital receipts and exportable records for
              full transparency.
            </p>
          </div>
        </div>

        <div class="feature-grid" style="margin-top: 18px">
          <div class="feature-card">
            <h4>Payment reminders</h4>
            <p>
              Automatic SMS and email reminders on contribution due dates. Keep
              everyone accountable and on schedule.
            </p>
          </div>
          <div class="feature-card">
            <h4>Record contributions</h4>
            <p>
              Log payments when received. Verify amounts and mark as confirmed.
              Track late or missing payments.
            </p>
          </div>
          <div class="feature-card">
            <h4>Digital receipts</h4>
            <p>
              Members receive instant digital receipts for every contribution.
              Downloadable and printable for records.
            </p>
          </div>
          <div class="feature-card">
            <h4>Payment status</h4>
            <p>
              View at a glance which members are paid up, pending or overdue.
              Filter and sort for quick reviews.
            </p>
          </div>
          <div class="feature-card">
            <h4>Export records</h4>
            <p>
              Export all contribution data to CSV or PDF. Perfect for audits,
              tax purposes and record-keeping.
            </p>
          </div>
          <div class="feature-card">
            <h4>Transaction history</h4>
            <p>
              Complete, searchable history of every payment and edit. Audit
              trail shows who did what and when.
            </p>
          </div>
        </div>
      </section>

      <!-- Financial Goals & Milestones -->
      <section class="service-section card" style="padding: 28px">
        <div class="section-header">
          <div class="section-icon">🎯</div>
          <div>
            <h2 class="section-title">Financial Goals & Milestones</h2>
            <p class="section-desc">
              Set targets, celebrate achievements and automate payouts.
            </p>
          </div>
        </div>

        <div class="feature-grid" style="margin-top: 18px">
          <div class="feature-card">
            <h4>Set savings goals</h4>
            <p>
              Define what your group is saving for: emergency fund, house,
              business investment or community project.
            </p>
          </div>
          <div class="feature-card">
            <h4>Track progress</h4>
            <p>
              Visual progress bars and charts show how close the group is to
              each goal. Celebrate incremental wins.
            </p>
          </div>
          <div class="feature-card">
            <h4>Schedule payouts</h4>
            <p>
              Plan when and how much each member receives. Automate distribution
              based on contribution or need.
            </p>
          </div>
          <div class="feature-card">
            <h4>Milestone celebrations</h4>
            <p>
              Trigger notifications and badges when goals are reached. Share joy
              and build group cohesion.
            </p>
          </div>
          <div class="feature-card">
            <h4>Fund allocation</h4>
            <p>
              Decide how funds are split: equal shares, proportional to
              contributions, or custom distribution rules.
            </p>
          </div>
          <div class="feature-card">
            <h4>Goal dashboards</h4>
            <p>
              Member-level view of their share, projected payout date and
              personal savings contribution rate.
            </p>
          </div>
        </div>
      </section>

      <!-- Analytics & Reporting -->
      <section class="service-section card" style="padding: 28px">
        <div class="section-header">
          <div class="section-icon">📊</div>
          <div>
            <h2 class="section-title">Analytics & Reporting</h2>
            <p class="section-desc">
              Deep insights into group health, growth and member behavior.
            </p>
          </div>
        </div>

        <div class="feature-grid" style="margin-top: 18px">
          <div class="feature-card">
            <h4>Savings trends</h4>
            <p>
              See how much your group has saved over time. Month-on-month growth
              rates and forward projections.
            </p>
          </div>
          <div class="feature-card">
            <h4>Member analysis</h4>
            <p>
              Who contributes most? Who's behind? Track individual and
              group-level contribution patterns.
            </p>
          </div>
          <div class="feature-card">
            <h4>Demographics</h4>
            <p>
              Breakdowns by gender, location, age and other fields. Understand
              your group's composition.
            </p>
          </div>
          <div class="feature-card">
            <h4>Custom reports</h4>
            <p>
              Build reports filtered by date, member, chama or metric. Export to
              CSV, PDF or print.
            </p>
          </div>
          <div class="feature-card">
            <h4>Admin dashboards</h4>
            <p>
              Real-time KPIs: total saved, contributions this period, members
              active, goals reached.
            </p>
          </div>
          <div class="feature-card">
            <h4>Forecasting</h4>
            <p>
              Project future savings based on historical data. Plan payouts and
              set realistic group goals.
            </p>
          </div>
        </div>
      </section>

      <!-- Security & Trust -->
      <section class="service-section card" style="padding: 28px">
        <div class="section-header">
          <div class="section-icon">🔒</div>
          <div>
            <h2 class="section-title">Security & Trust</h2>
            <p class="section-desc">
              Built-in safeguards and transparency to protect your group.
            </p>
          </div>
        </div>

        <div class="feature-grid" style="margin-top: 18px">
          <div class="feature-card">
            <h4>Role-based access</h4>
            <p>
              Granular permissions. Members can't edit others' data. Admins
              control what treasurers can see.
            </p>
          </div>
          <div class="feature-card">
            <h4>Audit logs</h4>
            <p>
              Every action is logged: who changed what, when and why. Full
              transparency for disputes or reviews.
            </p>
          </div>
          <div class="feature-card">
            <h4>Data encryption</h4>
            <p>
              All member data and financial info encrypted in transit and at
              rest. Banks-grade security.
            </p>
          </div>
          <div class="feature-card">
            <h4>Community guidelines</h4>
            <p>
              Built-in policies on conduct, contributions and conflicts. Enforce
              standards and protect trust.
            </p>
          </div>
          <div class="feature-card">
            <h4>Dispute resolution</h4>
            <p>
              Report concerns anonymously. Escalate to admin for mediation. Keep
              groups harmonious.
            </p>
          </div>
          <div class="feature-card">
            <h4>Session security</h4>
            <p>
              Automatic timeouts, password recovery and device management. Your
              data stays safe.
            </p>
          </div>
        </div>
      </section>

      <!-- Community Features -->
      <section class="service-section card" style="padding: 28px">
        <div class="section-header">
          <div class="section-icon">🤝</div>
          <div>
            <h2 class="section-title">Community Features</h2>
            <p class="section-desc">
              Build stronger bonds and share knowledge with your chama.
            </p>
          </div>
        </div>

        <div class="feature-grid" style="margin-top: 18px">
          <div class="feature-card">
            <h4>Group forums</h4>
            <p>
              Threaded discussions about chama business, goals and community.
              Keep conversations organized.
            </p>
          </div>
          <div class="feature-card">
            <h4>Member messaging</h4>
            <p>
              Direct chats between members. Share ideas, ask questions or plan
              informal meetings.
            </p>
          </div>
          <div class="feature-card">
            <h4>Event scheduling</h4>
            <p>
              Plan meetings, celebrations and milestones. Send invites and track
              RSVPs in one place.
            </p>
          </div>
          <div class="feature-card">
            <h4>Knowledge sharing</h4>
            <p>
              Document group learnings, best practices and lessons. Help new
              chamas avoid past mistakes.
            </p>
          </div>
          <div class="feature-card">
            <h4>Achievements</h4>
            <p>
              Badges and shout-outs for consistent contributors, patience and
              good citizenship in the group.
            </p>
          </div>
          <div class="feature-card">
            <h4>Group profile</h4>
            <p>
              Showcase your chama's mission, members and impact. Attract
              like-minded groups and build networks.
            </p>
          </div>
        </div>
      </section>

      <!-- Why Choose ChamaOS -->
      <section class="card" style="padding: 28px; margin-top: 28px">
        <h2 class="h1" style="text-align: center">Why choose ChamaOS?</h2>

        <div class="highlights">
          <div class="highlight-badge">
            <div class="highlight-value">100%</div>
            <div class="highlight-label">Transparent</div>
          </div>
          <div class="highlight-badge">
            <div class="highlight-value">24/7</div>
            <div class="highlight-label">Accessible</div>
          </div>
          <div class="highlight-badge">
            <div class="highlight-value">∞</div>
            <div class="highlight-label">Scalable</div>
          </div>
          <div class="highlight-badge">
            <div class="highlight-value">🔒</div>
            <div class="highlight-label">Secure</div>
          </div>
        </div>
      </section>

      <!-- Call to Action -->
      <section class="cta-strip">
        <h3>Start your chama journey today</h3>
        <p style="margin: 0; color: var(--slate-gray); font-size: 14px">
          Join thousands of groups saving, growing and thriving together.
        </p>
        <div class="cta-strip-actions">
          <a class="btn btn-primary" href="/signup">Create a chama</a>
          <a class="btn btn-secondary" href="/login">Sign in</a>
          <a class="btn btn-ghost" href="/">Back to home</a>
        </div>
      </section>

      <%- include('../partials/footer') %>
    </main>
  </body>
</html>
