<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — Dashboard</title>
  </head>
  <body>
    <%- include('../partials/header', { brandTagline: 'Your chama, your goals', navItems: [ { text: 'Services', href: '/services' }, { text: 'Profile', href: '/member/profile' }, { text: 'Logout', href: '/login' } ] }) %>

    <main class="container">
      <section class="card">
        <div class="page-header">
          <div>
            <h1 class="h1">Welcome, member</h1>
            <p class="lead">Your chama's savings and milestones at a glance.</p>
          </div>
          <div class="actions">
            <a class="btn btn-primary" href="#">New contribution</a>
            <a class="btn btn-ghost" href="#">View chamas</a>
          </div>
        </div>
      </section>

      <section class="welcome-strip">
        <div class="small">You are part of 3 chamas</div>
        <h3 class="h2">Active & growing</h3>
        <div style="margin-top: 10px">
          <span class="badge badge-success">Umoja</span>
          <span class="badge badge-community">Kazi</span>
          <span class="badge badge-community">Nyumba</span>
        </div>
      </section>

      <section class="metrics-grid">
        <div class="metric-card">
          <div class="metric-label">Total saved (all chamas)</div>
          <div class="metric-value value-deep">KES 124,300</div>
          <div class="small" style="margin-top: 8px">↑ 12% from last month</div>
        </div>

        <div class="metric-card">
          <div class="metric-label">Your next contribution</div>
          <div class="metric-value value-gold">KES 8,500</div>
          <div class="small" style="margin-top: 8px">Due in 5 days • Umoja</div>
        </div>

        <div class="metric-card">
          <div class="metric-label">Pending payout</div>
          <div class="metric-value value-success">KES 15,000</div>
          <div class="small" style="margin-top: 8px">
            Nyumba milestone reached
          </div>
        </div>

        <div class="metric-card">
          <div class="metric-label">Your contribution rate</div>
          <div class="metric-value value-deep">100%</div>
          <div class="small" style="margin-top: 8px">No missed payments 👏</div>
        </div>
      </section>

      <section class="card" style="margin-top: 24px">
        <h3 class="h2">Recent activity</h3>
        <table
          class="table"
          aria-describedby="activity-log"
          style="margin-top: 12px"
        >
          <thead>
            <tr>
              <th>Date</th>
              <th>Chama</th>
              <th>Action</th>
              <th>Amount</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Feb 14, 2026</td>
              <td>Umoja</td>
              <td>Contribution</td>
              <td>KES 8,500</td>
              <td><span class="badge badge-success">Confirmed</span></td>
            </tr>
            <tr>
              <td>Feb 10, 2026</td>
              <td>Kazi</td>
              <td>Contribution</td>
              <td>KES 5,000</td>
              <td><span class="badge badge-success">Confirmed</span></td>
            </tr>
            <tr>
              <td>Feb 7, 2026</td>
              <td>Nyumba</td>
              <td>Payout</td>
              <td>KES 15,000</td>
              <td><span class="badge badge-success">Completed</span></td>
            </tr>
            <tr>
              <td>Feb 1, 2026</td>
              <td>Umoja</td>
              <td>Contribution</td>
              <td>KES 8,500</td>
              <td><span class="badge badge-success">Confirmed</span></td>
            </tr>
          </tbody>
        </table>
      </section>

      <section class="card" style="margin-top: 24px">
        <h3 class="h2">Quick links</h3>
        <div
          style="
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 12px;
            margin-top: 12px;
          "
        >
          <a class="btn btn-ghost" href="/member/profile">View my profile</a>
          <a class="btn btn-ghost" href="/services">Services & features</a>
          <a class="btn btn-ghost" href="#">Download report</a>
          <a class="btn btn-ghost" href="#">Contact support</a>
        </div>
      </section>

      <%- include('../partials/footer') %>
    </main>
  </body>
</html>
