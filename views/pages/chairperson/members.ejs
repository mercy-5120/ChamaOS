<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — Chairperson Member Oversight</title>
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="/css/chairperson.css" />
  </head>
  <body>
    <main class="container dashboard-layout">
      <%- include('../partials/chairpersonsidebar') %>

      <section class="dashboard-content">
        <div class="page-header">
          <div>
            <h1 class="h1">Member Oversight</h1>
            <p class="lead">
              Review member status, approvals, attendance, and disciplinary
              records.
            </p>
          </div>
        </div>

        <section class="dashboard-section">
          <h2 class="h2">Pending Join Requests</h2>
          <div class="card">
            <table class="table">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Phone</th>
                  <th>Requested On</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td colspan="4">No pending join requests available.</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <section class="dashboard-section">
          <h2 class="h2">Active Members</h2>
          <div class="card">
            <table class="table">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Role</th>
                  <th>Attendance</th>
                  <th>Contribution Status</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td colspan="5">No active member records available.</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <section class="dashboard-section">
          <h2 class="h2">Disciplinary Records</h2>
          <div class="card">
            <table class="table">
              <thead>
                <tr>
                  <th>Member</th>
                  <th>Issue</th>
                  <th>Reported On</th>
                  <th>Status</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td colspan="5">No disciplinary records available.</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>
      </section>
    </main>
  </body>
</html>
