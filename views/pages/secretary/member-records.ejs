<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — Member Records</title>
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="/css/secretary.css" />
  </head>
  <body>
    <main class="container dashboard-layout">
      <%- include('../partials/secretarysidebar') %>

      <section class="dashboard-content">
        <div class="page-header">
          <div>
            <h1 class="h1">Member Records</h1>
            <p class="lead">
              Maintain member register and add new members to the group.
            </p>
          </div>
        </div>

        <% if (typeof success !== 'undefined' && success) { %>
          <div class="alert alert-success" style="color:#1e6b41;background:#e8f7ee;border:1px solid #2a9d62;border-radius:6px;padding:0.75rem 1rem;margin-bottom:1rem;">
            <%= success %>
          </div>
        <% } %>

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert-error" style="color:#c0392b;background:#fdecea;border:1px solid #e74c3c;border-radius:6px;padding:0.75rem 1rem;margin-bottom:1rem;">
            <%= error %>
          </div>
        <% } %>

        <!-- Add New Member -->
        <section class="dashboard-section">
          <h2 class="h2">Add New Member</h2>
          <div class="card form-card member-add-card">
            <div class="member-add-header">
              <p class="member-add-kicker">Quick Onboarding</p>
              <p class="member-add-subtitle">
                Add a member account to this chama. The account will be created as
                <strong>member</strong> by default.
              </p>
            </div>

            <form class="form-group member-add-form" action="/secretary/add-member" method="POST" autocomplete="on">
              <div class="form-row">
                <div class="form-col full-width">
                  <label for="member-full-name" class="form-label">Full Name *</label>
                  <input
                    type="text"
                    id="member-full-name"
                    name="full_name"
                    class="form-control"
                    placeholder="e.g., John Kamau"
                    required
                  />
                </div>
              </div>

              <div class="form-row member-add-grid">
                <div class="form-col">
                  <label for="member-email" class="form-label">Email *</label>
                  <input
                    type="email"
                    id="member-email"
                    name="email"
                    class="form-control"
                    placeholder="email@example.com"
                    required
                  />
                </div>
                <div class="form-col">
                  <label for="member-phone" class="form-label"
                    >Phone Number *</label
                  >
                  <input
                    type="tel"
                    id="member-phone"
                    name="phone_number"
                    class="form-control"
                    placeholder="+254 712 345 678"
                    required
                  />
                </div>
              </div>

              <div class="form-row">
                <div class="form-col full-width">
                  <label for="member-password" class="form-label">Temporary Password *</label>
                  <input
                    type="password"
                    id="member-password"
                    name="password"
                    class="form-control"
                    placeholder="Set a temporary password"
                    required
                  />
                </div>
              </div>

              <div class="member-add-actions">
                <button type="submit" class="btn btn-primary">Add Member</button>
              </div>
            </form>
          </div>
        </section>

        <!-- Member Register -->
        <section class="dashboard-section">
          <h2 class="h2">Member Register</h2>
          <div class="card">
            <div class="search-filter-bar">
              <div class="search-box">
                <input
                  type="text"
                  placeholder="Search members by name..."
                  class="form-control"
                />
              </div>
              <div class="filter-controls">
                <select class="form-control form-control-sm">
                  <option value="">All Members</option>
                  <option value="active">Active</option>
                  <option value="inactive">Inactive</option>
                </select>
              </div>
            </div>

            <table class="table">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Role</th>
                  <th>Email</th>
                  <th>Phone</th>
                  <th>Join Date</th>
                </tr>
              </thead>
              <tbody>
                <% if (members && members.length > 0) { %>
                  <% members.forEach((member) => { %>
                    <tr>
                      <td><%= member.full_name %></td>
                      <td><%= member.role || 'member' %></td>
                      <td><%= member.email || '-' %></td>
                      <td><%= member.phone_number || '-' %></td>
                      <td><%= member.joined_date || '-' %></td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="5">No member records available.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </section>

      </section>
    </main>
  </body>
</html>
