                  padding: 10px;
                  border: 1px solid #e0e0e0;
                  border-radius: 4px;
                "
              />
            </div>

            <table class="table">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Phone</th>
                  <th>Email</th>
                  <th>Role</th>
                  <th>Member Since</th>
                  <th>Contact</th>
                </tr>
              </thead>
              <tbody>
