<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — Group Information</title>
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="/css/member.css" />
  </head>
  <body>
    <main class="container dashboard-layout">
      <%- include('../partials/membersidebar') %>

      <section class="dashboard-content">
        <div class="page-header">
          <div>
            <h1 class="h1">Group Information</h1>
            <p class="lead">Learn about your group, members, and policies</p>
          </div>
        </div>

        <!-- GROUP OVERVIEW -->
        <section class="dashboard-section">
          <h2 class="h2">Group Overview</h2>
          <div class="card group-overview">
            <div class="group-header">
              <h3><%= groupInfo.chama_name || '-' %></h3>
              <p class="small"><%= groupInfo.description || 'No group description available.' %></p>
            </div>

            <div class="group-stats">
              <div class="stat">
                <strong>Total Members:</strong>
                <p><%= memberDirectory.length %></p>
              </div>
              <div class="stat">
                <strong>Founded:</strong>
                <p><%= groupInfo.created_at || '-' %></p>
              </div>
              <div class="stat">
                <strong>Meeting Frequency:</strong>
                <p><%= groupInfo.meeting_day || '-' %></p>
              </div>
              <div class="stat">
                <strong>Group Type:</strong>
                <p><%= Number(groupInfo.is_active) === 1 ? 'Active Chama' : 'Inactive Chama' %></p>
              </div>
            </div>

            <div
              style="
                margin-top: 20px;
                padding-top: 20px;
                border-top: 1px solid #e0e0e0;
              "
            >
              <h4>Group Mission</h4>
              <p><%= groupInfo.description || 'No mission statement available.' %></p>
            </div>
          </div>
        </section>

        <!-- GROUP FINANCIAL SUMMARY -->
        <section class="dashboard-section">
          <h2 class="h2">Financial Summary</h2>
          <div class="metrics-grid">
            <div class="metric-card">
              <div class="metric-label">Total Savings</div>
              <div class="metric-value value-success"><%= groupInfo.currency || 'KES' %> <%= Number(financialSummary.total_savings || 0).toLocaleString() %></div>
              <div class="small" style="margin-top: 8px">From completed contributions</div>
            </div>

            <div class="metric-card">
              <div class="metric-label">Total Loans Disbursed</div>
              <div class="metric-value value-info"><%= groupInfo.currency || 'KES' %> <%= Number(financialSummary.total_loans_disbursed || 0).toLocaleString() %></div>
              <div class="small" style="margin-top: 8px">All loans issued</div>
            </div>

            <div class="metric-card">
              <div class="metric-label">Active Loans</div>
              <div class="metric-value value-warning"><%= financialSummary.active_loans || 0 %></div>
              <div class="small" style="margin-top: 8px">Loans currently active</div>
            </div>

            <div class="metric-card">
              <div class="metric-label">Total Loan Repayments</div>
              <div class="metric-value value-success"><%= groupInfo.currency || 'KES' %> <%= Number(financialSummary.total_repayments || 0).toLocaleString() %></div>
              <div class="small" style="margin-top: 8px">Completed loan repayments</div>
            </div>
          </div>
        </section>

        <!-- MEMBER DIRECTORY -->
        <section class="dashboard-section">
          <h2 class="h2">Member Directory</h2>
          <div class="card">
            <div style="margin-bottom: 20px">
              <input
                type="text"
                placeholder="Search members by name, phone..."
                class="search-input"
                style="
                  width: 100%;
                  padding: 10px;
                  border: 1px solid #e0e0e0;
                  border-radius: 4px;
                "
              />
            </div>

            <table class="table">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Phone</th>
                  <th>Email</th>
                  <th>Role</th>
                  <th>Member Since</th>
                  <th>Contact</th>
                </tr>
              </thead>
              <tbody>
                <% if (memberDirectory && memberDirectory.length > 0) { %>
                  <% memberDirectory.forEach(function(member) { %>
                    <tr>
                      <td><%= member.full_name %></td>
                      <td><%= member.phone_number || '-' %></td>
                      <td><%= member.email || '-' %></td>
                      <td><%= member.role || 'member' %></td>
                      <td><%= member.joined_date || '-' %></td>
                      <td>
                        <% if (member.phone_number) { %>
                          <a href="tel:<%= member.phone_number %>" class="btn btn-secondary btn-sm">Call</a>
                        <% } else { %>
                          -
                        <% } %>
                      </td>
                    </tr>
                  <% }); %>
                <% } else { %>
                  <tr>
                    <td colspan="6">No members available.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
            <p class="small" style="margin-top: 15px">Showing <%= memberDirectory.length %> members.</p>
          </div>
        </section>

        <!-- GROUP BYLAWS & RULES -->
        <section class="dashboard-section">
          <h2 class="h2">Group Bylaws & Rules</h2>
          <div class="card">
            <div class="accordion">
              <% const constitutionDocs = (governanceDocuments || []).filter(function(doc) { return doc.document_type === 'constitution'; }); %>
              <% const bylawsDocs = (governanceDocuments || []).filter(function(doc) { return doc.document_type === 'bylaws'; }); %>

              <h4>Constitution</h4>
              <% if (constitutionDocs.length > 0) { %>
                <ul>
                  <% constitutionDocs.forEach(function(doc) { %>
                    <li>
                      <a href="<%= doc.file_path %>" target="_blank" rel="noopener"><%= doc.title %></a>
                      <span class="small"> - Uploaded: <%= doc.uploaded_at %></span>
                    </li>
                  <% }); %>
                </ul>
              <% } else { %>
                <p>No constitution uploaded yet.</p>
              <% } %>

              <h4 style="margin-top: 14px">Bylaws</h4>
              <% if (bylawsDocs.length > 0) { %>
                <ul>
                  <% bylawsDocs.forEach(function(doc) { %>
                    <li>
                      <a href="<%= doc.file_path %>" target="_blank" rel="noopener"><%= doc.title %></a>
                      <span class="small"> - Uploaded: <%= doc.uploaded_at %></span>
                    </li>
                  <% }); %>
                </ul>
              <% } else { %>
                <p>No bylaws uploaded yet.</p>
              <% } %>
            </div>
          </div>
        </section>

        <!-- DOWNLOAD DOCUMENTS -->
        <section class="dashboard-section">
          <h2 class="h2">Important Documents</h2>
          <div class="card">
            <div class="document-list">
              <% if (governanceDocuments && governanceDocuments.length > 0) { %>
                <ul>
                  <% governanceDocuments.forEach(function(doc) { %>
                    <li>
                      <a href="<%= doc.file_path %>" target="_blank" rel="noopener"><%= doc.file_name %></a>
                      <span class="small"> (<%= doc.document_type === 'constitution' ? 'Constitution' : 'Bylaws' %>)</span>
                    </li>
                  <% }); %>
                </ul>
              <% } else { %>
                <p>No documents available.</p>
              <% } %>
            </div>
          </div>
        </section>

        <div style="margin-top: 30px; padding-bottom: 30px">
          <a href="/member/dashboard" class="btn btn-secondary"
            >Back to Dashboard</a
          >
        </div>
      </section>
    </main>

    <script>
      function toggleAccordion(header) {
        const content = header.nextElementSibling;
        const isOpen = content.style.display !== "none";

        // Close all other accordion items
        document.querySelectorAll(".accordion-content").forEach((item) => {
          item.style.display = "none";
        });
        document.querySelectorAll(".accordion-header span").forEach((span) => {
          span.textContent = "+";
        });

        // Toggle current item
        if (!isOpen) {
          content.style.display = "block";
          header.querySelector("span").textContent = "−";
        }
      }
    </script>
  </body>
</html>
