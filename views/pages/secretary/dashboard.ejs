<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — Secretary Dashboard</title>
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="/css/secretary.css" />
  </head>
  <body>
    <main class="container dashboard-layout">
      <%- include('../partials/secretarysidebar') %>

      <section class="dashboard-content">
        <div class="page-header">
          <div>
            <h1 class="h1">Secretary Dashboard</h1>
            <p class="lead">
              Manage meetings, documents, communications, and member records.
            </p>
          </div>
        </div>

        <!-- Dashboard Overview Section -->
        <section class="dashboard-section">
          <h2 class="h2">Overview</h2>
          <div class="metrics-grid">
            <div class="metric-card">
              <div class="metric-label">Recent Meetings</div>
              <div class="metric-value value-info">-</div>
            </div>
            <div class="metric-card">
              <div class="metric-label">Upcoming Meetings</div>
              <div class="metric-value value-warning">-</div>
            </div>
            <div class="metric-card">
              <div class="metric-label">Pending Documents</div>
              <div class="metric-value value-coral">-</div>
            </div>
            <div class="metric-card">
              <div class="metric-label">Total Members</div>
              <div class="metric-value value-success">-</div>
            </div>
          </div>
        </section>

        <!-- Recent Meetings -->
        <section class="dashboard-section">
          <div class="section-header">
            <h2 class="h2">Recent Meetings (Last 3)</h2>
            <a href="/secretary/meetings" class="btn btn-link">View All</a>
          </div>
          <div class="card">
            <table class="table">
              <thead>
                <tr>
                  <th>Meeting Title</th>
                  <th>Date</th>
                  <th>Attendees</th>
                  <th>Status</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td colspan="5">No recent meetings available.</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <!-- Upcoming Meetings -->
        <section class="dashboard-section">
          <div class="section-header">
            <h2 class="h2">Upcoming Meetings (Next 3)</h2>
            <a href="/secretary/calendar" class="btn btn-link">View Calendar</a>
          </div>
          <div class="card">
            <table class="table">
              <thead>
                <tr>
                  <th>Meeting Title</th>
                  <th>Scheduled Date</th>
                  <th>Time</th>
                  <th>Location</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td colspan="5">No upcoming meetings available.</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <!-- Pending Documents -->
        <section class="dashboard-section">
          <div class="section-header">
            <h2 class="h2">Pending Documents to Upload</h2>
            <a href="/secretary/documents" class="btn btn-link">Manage All</a>
          </div>
          <div class="card documents-list">
            <p>No pending documents available.</p>
          </div>
        </section>

        <!-- Attendance Statistics -->
        <section class="dashboard-section">
          <div class="section-header">
            <h2 class="h2">Attendance Statistics</h2>
            <a href="/secretary/member-records" class="btn btn-link"
              >View Details</a
            >
          </div>
          <div class="card">
            <div class="stats-grid">
              <div class="stat-box">
                <div class="stat-label">Average Attendance Rate</div>
                <div class="stat-value">-</div>
                <div class="stat-bar">
                  <div class="stat-bar-fill" style="width: 0%"></div>
                </div>
              </div>
              <div class="stat-box">
                <div class="stat-label">Members Present (Last Meeting)</div>
                <div class="stat-value">-</div>
                <div class="stat-bar">
                  <div class="stat-bar-fill" style="width: 0%"></div>
                </div>
              </div>
              <div class="stat-box">
                <div class="stat-label">Members Absent (Last Meeting)</div>
                <div class="stat-value">-</div>
                <div class="stat-bar">
                  <div class="stat-bar-fill" style="width: 0%"></div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Quick Actions -->
        <section class="dashboard-section">
          <h2 class="h2">Quick Actions</h2>
          <div class="action-buttons">
            <a href="/secretary/meetings" class="btn btn-primary"
              >Create New Meeting</a
            >
            <a href="/secretary/documents" class="btn btn-primary"
              >Upload Documents</a
            >
            <a href="/secretary/communications" class="btn btn-primary"
              >Send Announcement</a
            >
            <a href="/secretary/calendar" class="btn btn-secondary"
              >View Calendar</a
            >
          </div>
        </section>
      </section>
    </main>
  </body>
</html>
