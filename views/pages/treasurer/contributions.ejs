<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — Contributions (Treasurer)</title>
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="/css/treasurer.css" />
  </head>
  <body>
    <main class="container dashboard-layout">
      <%- include('../partials/treasurersidebar') %>

      <section class="dashboard-content">
        <div class="page-header">
          <div>
            <h1 class="h1">Contributions</h1>
            <p class="lead">Record and reconcile member contributions.</p>
          </div>
          <div class="actions">
            <a href="#record" class="btn btn-primary">Record Contribution</a>
            <a href="#import" class="btn btn-ghost">Import M-Pesa</a>
          </div>
        </div>

        <% if (success) { %>
          <div class="alert alert-success"><%= success %></div>
        <% } %>
        <% if (error) { %>
          <div class="alert alert-error"><%= error %></div>
        <% } %>

        <section class="dashboard-section">
          <h2 class="h2">Recent Contributions</h2>
          <div class="card">
            <table class="table">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Member</th>
                  <th>Amount</th>
                  <th>Method</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% if (recentContributions && recentContributions.length > 0) { %>
                  <% recentContributions.forEach(function(tx) { %>
                    <tr>
                      <td><%= tx.contribution_date %></td>
                      <td><%= tx.member_name %></td>
                      <td>KES <%= Number(tx.amount).toLocaleString() %></td>
                      <td><%= (tx.description || '').replace('Payment Method: ', '') || '-' %></td>
                      <td><%= tx.status %></td>
                    </tr>
                  <% }); %>
                <% } else { %>
                  <tr>
                    <td colspan="5">No contributions available.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </section>

        <section class="dashboard-section">
          <h2 class="h2">Actions</h2>
          <div class="card">
            <form method="POST" action="/treasurer/contributions/record" id="record">
              <div class="form-grid">
                <div class="form-group">
                  <label for="member">Member</label>
                  <select id="member" name="user_id" required>
                    <option value="">-- Select member --</option>
                    <% if (members && members.length > 0) { %>
                      <% members.forEach(function(member) { %>
                        <option value="<%= member.user_id %>"><%= member.full_name %></option>
                      <% }); %>
                    <% } %>
                  </select>
                </div>
                <div class="form-group">
                  <label for="amount">Amount (KES)</label>
                  <input id="amount" name="amount" type="number" min="1" required />
                </div>
                <div class="form-group">
                  <label for="method">Payment Method</label>
                  <select id="method" name="method" required>
                    <option value="">-- Select payment method --</option>
                    <option value="M-Pesa">M-Pesa</option>
                    <option value="Bank Transfer">Bank Transfer</option>
                    <option value="Cash">Cash</option>
                  </select>
                </div>
                <div class="form-group">
                  <label for="date">Date</label>
                  <input id="date" name="contribution_date" type="date" required />
                </div>
              </div>

              <div style="margin-top: 16px">
                <button class="btn btn-primary" type="submit">
                  Save Contribution
                </button>
              </div>
            </form>
          </div>
        </section>
      </section>
    </main>
  </body>
</html>
