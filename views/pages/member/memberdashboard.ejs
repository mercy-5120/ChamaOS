<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — Member Dashboard</title>
    <link rel="stylesheet" href="/css/app.css" />
  </head>
  <body>

    <main class="container dashboard-layout">
      <%- include('../partials/membersidebar') %>

      <section class="dashboard-content">
        <div class="page-header">
          <div>
            <h1 class="h1">Dashboard</h1>
            <p class="lead">Welcome back! Here's your chama overview.</p>
          </div>
        </div>

        <!-- CONTRIBUTION SUMMARY -->
        <section class="dashboard-section">
          <h2 class="h2">Contribution Summary</h2>
          <div class="metrics-grid">
            <div class="metric-card">
              <div class="metric-label">Total Contributed</div>
              <div class="metric-value value-deep">KES 45,000</div>
              <div class="small" style="margin-top: 8px">All time contribution</div>
            </div>

            <div class="metric-card">
              <div class="metric-label">Last Payment</div>
              <div class="metric-value value-success">KES 5,000</div>
              <div class="small" style="margin-top: 8px">January 20, 2026</div>
            </div>

            <div class="metric-card">
              <div class="metric-label">Next Due Date</div>
              <div class="metric-value value-warning">February 28</div>
              <div class="small" style="margin-top: 8px">KES 5,000 expected</div>
            </div>
          </div>
        </section>

        <!-- LOAN STATUS -->
        <section class="dashboard-section">
          <h2 class="h2">Active Loans</h2>
          <div class="card">
            <table class="table">
              <thead>
                <tr>
                  <th>Loan ID</th>
                  <th>Amount Borrowed</th>
                  <th>Amount Repaid</th>
                  <th>Balance</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>#LOAN001</td>
                  <td>KES 30,000</td>
                  <td>KES 12,000</td>
                  <td>KES 18,000</td>
                  <td><span class="badge badge-info">Active</span></td>
                </tr>
              </tbody>
            </table>
            <div style="margin-top: 15px">
              <a href="/member/loans" class="btn btn-primary">Manage Loans</a>
            </div>
          </div>
        </section>

        <!-- ANNOUNCEMENTS -->
        <section class="dashboard-section">
          <h2 class="h2">Recent Announcements</h2>
          <div class="card announcement-box">
            <div class="announcement">
              <div class="announcement-date">Feb 22, 2026</div>
              <h4>Monthly Meeting Scheduled</h4>
              <p>Our next chama meeting is scheduled for February 28, 2026 at 6:00 PM at the community center.</p>
            </div>
            <hr style="margin: 15px 0" />
            <div class="announcement">
              <div class="announcement-date">Feb 15, 2026</div>
              <h4>New Loan Policy Updated</h4>
              <p>We've updated our loan policy to include better repayment terms. Please review the new guidelines.</p>
            </div>
            <hr style="margin: 15px 0" />
            <div class="announcement">
              <div class="announcement-date">Feb 10, 2026</div>
              <h4>Group Financial Report</h4>
              <p>The February financial report is now available. Total savings increased by 15% this month.</p>
            </div>
          </div>
        </section>

        <!-- UPCOMING MEETINGS -->
        <section class="dashboard-section">
          <h2 class="h2">Upcoming Meetings</h2>
          <div class="card">
            <div class="meeting-list">
              <div class="meeting-item">
                <div class="meeting-date">Feb 28, 2026</div>
                <div class="meeting-details">
                  <h4>Monthly General Meeting</h4>
                  <p><strong>Time:</strong> 6:00 PM - 8:00 PM</p>
                  <p><strong>Venue:</strong> Community Center, Room A</p>
                  <p><strong>Agenda:</strong> Financial updates, loan approvals, member contributions</p>
                </div>
              </div>
              <hr style="margin: 15px 0" />
              <div class="meeting-item">
                <div class="meeting-date">Mar 7, 2026</div>
                <div class="meeting-details">
                  <h4>Finance Committee Meeting</h4>
                  <p><strong>Time:</strong> 5:00 PM - 6:00 PM</p>
                  <p><strong>Venue:</strong> Virtual (Zoom)</p>
                  <p><strong>Agenda:</strong> Review loan applications, budget planning</p>
                </div>
              </div>
            </div>
            <div style="margin-top: 15px">
              <a href="/member/meetings" class="btn btn-primary">View All Meetings</a>
            </div>
          </div>
        </section>

        <div style="margin-top: 30px; padding-bottom: 30px">
          <a href="/member/contributions" class="btn btn-secondary">View Contributions</a>
          <a href="/member/group" class="btn btn-secondary">View Group Info</a>
        </div>
      </section>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
