<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — Meetings</title>
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="/css/member.css" />
  </head>
  <body>
    <main class="container dashboard-layout">
      <%- include('../partials/membersidebar') %>

      <section class="dashboard-content">
        <div class="page-header">
          <div>
            <h1 class="h1">Meetings</h1>
            <p class="lead">View upcoming meetings and access past minutes</p>
          </div>
        </div>

        <!-- UPCOMING MEETINGS -->
        <section class="dashboard-section">
          <h2 class="h2">Upcoming Meetings</h2>
          <div class="card">
            <div class="meetings-list">
              <% if (upcomingMeetings && upcomingMeetings.length > 0) { %>
                <% upcomingMeetings.forEach(function(meeting) { %>
                  <div class="announcement-item" style="margin-bottom: 12px;">
                    <div class="announcement-meta">
                      <span class="announcement-title"><%= meeting.meeting_title %></span>
                      <% if (meeting.meeting_kind === 'special') { %>
                        <span class="announcement-badge badge-info">Special</span>
                      <% } %>
                      <span class="announcement-badge badge-warning">Upcoming</span>
                    </div>
                    <p class="announcement-content">
                      <strong>Date:</strong> <%= meeting.meeting_date %> <%= meeting.meeting_time || '' %><br />
                      <strong>Location:</strong> <%= meeting.location %><br />
                      <strong>Agenda:</strong> <%= meeting.agenda %>
                    </p>
                  </div>
                <% }); %>
              <% } else { %>
                <p>No upcoming meetings available.</p>
              <% } %>
            </div>
          </div>
        </section>

        <!-- ALL SPECIAL MEETINGS -->
        <section class="dashboard-section">
          <h2 class="h2">All Special Meetings</h2>
          <div class="card">
            <table class="table">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Meeting</th>
                  <th>Type</th>
                  <th>Status</th>
                  <th>Location</th>
                </tr>
              </thead>
              <tbody>
                <% if (specialMeetings && specialMeetings.length > 0) { %>
                  <% specialMeetings.forEach(function(meeting) { %>
                    <tr>
                      <td><%= meeting.meeting_date %> <%= meeting.meeting_time || '' %></td>
                      <td><%= meeting.meeting_title || 'Special Meeting' %></td>
                      <td><span class="badge badge-info">Special</span></td>
                      <td style="text-transform: capitalize;"><%= meeting.meeting_status %></td>
                      <td><%= meeting.location || '-' %></td>
                    </tr>
                  <% }); %>
                <% } else { %>
                  <tr>
                    <td colspan="5">No special meetings available.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </section>

        <!-- PAST MEETINGS & MINUTES -->
        <section class="dashboard-section">
          <h2 class="h2">Past Meeting Minutes</h2>
          <div class="card">
            <table class="table">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Meeting</th>
                  <th>Attendees</th>
                  <th>Minutes</th>
                  <th>Decisions</th>
                  <th>Download</th>
                </tr>
              </thead>
              <tbody>
                <% if (pastMeetings && pastMeetings.length > 0) { %>
                  <% pastMeetings.forEach(function(meeting) { %>
                    <tr>
                      <td><%= meeting.meeting_date %></td>
                      <td>
                        <%= meeting.meeting_title %>
                        <% if (meeting.meeting_kind === 'special') { %>
                          <span class="badge badge-info" style="margin-left:6px;">Special</span>
                        <% } %>
                      </td>
                      <td>-</td>
                      <td><%= meeting.agenda ? 'Available' : '-' %></td>
                      <td><%= meeting.decisions || '-' %></td>
                      <td>-</td>
                    </tr>
                  <% }); %>
                <% } else { %>
                  <tr>
                    <td colspan="6">No past meeting records available.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </section>

        <!-- ATTENDANCE HISTORY -->
        <section class="dashboard-section">
          <h2 class="h2">Your Attendance</h2>
          <div class="card">
            <div class="metrics-grid">
              <div class="metric-card">
                <div class="metric-label">Total Meetings</div>
                <div class="metric-value"><%= attendanceStats.totalMeetings %></div>
              </div>

              <div class="metric-card">
                <div class="metric-label">Attended</div>
                <div class="metric-value value-success"><%= attendanceStats.attended %></div>
              </div>

              <div class="metric-card">
                <div class="metric-label">Attendance Rate</div>
                <div class="metric-value value-success"><%= attendanceStats.rate %>%</div>
              </div>

              <div class="metric-card">
                <div class="metric-label">Absent</div>
                <div class="metric-value"><%= attendanceStats.absent %></div>
              </div>
            </div>

            <table class="table" style="margin-top: 25px">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Meeting</th>
                  <th>Your Status</th>
                </tr>
              </thead>
              <tbody>
                <% if (pastMeetings && pastMeetings.length > 0) { %>
                  <% pastMeetings.forEach(function(meeting) { %>
                    <% var attStatus = attendanceMap[meeting.meeting_id]; %>
                    <tr>
                      <td><%= meeting.meeting_date %></td>
                      <td><%= meeting.meeting_title || 'Meeting' %></td>
                      <td>
                        <% if (attStatus === 1) { %>
                          <span style="color: #28a745; font-weight: 600;">&#10003; Present</span>
                        <% } else if (attStatus === 0) { %>
                          <span style="color: #dc3545; font-weight: 600;">&#10007; Absent</span>
                        <% } else { %>
                          <span style="color: #6c757d;">— Not Recorded</span>
                        <% } %>
                      </td>
                    </tr>
                  <% }); %>
                <% } else { %>
                  <tr>
                    <td colspan="3">No past meeting records available.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </section>

        <div style="margin-top: 30px; padding-bottom: 30px">
          <a href="/member/dashboard" class="btn btn-secondary"
            >Back to Dashboard</a
          >
        </div>
      </section>
    </main>

    <script>
      function markAttendance(meetingId) {
        alert("Attendance marked for meeting: " + meetingId);
      }

      function viewMinutes(meetingId) {
        alert("Viewing minutes for meeting: " + meetingId);
      }

      function viewDecisions(meetingId) {
        alert("Viewing decisions for meeting: " + meetingId);
      }
    </script>
  </body>
</html>
