<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — Treasurer Settings</title>
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="/css/treasurer.css" />
  </head>
  <body>
    <main class="container dashboard-layout">
      <%- include('../partials/treasurersidebar') %>

      <section class="dashboard-content">
        <div class="page-header">
          <div>
            <h1 class="h1">Settings</h1>
            <p class="lead">
              Manage contribution amounts, interest rates and limits.
            </p>
          </div>
        </div>

        <section class="dashboard-section">
          <h2 class="h2">Financial Settings</h2>
          <div class="card">
            <form>
              <div class="form-grid">
                <div class="form-group">
                  <label>Monthly Contribution (KES)</label>
                  <input type="number" />
                </div>
                <div class="form-group">
                  <label>Default Interest Rate (%)</label>
                  <input type="number" />
                </div>
                <div class="form-group">
                  <label>Loan Approval Limit (KES)</label>
                  <input type="number" />
                </div>
              </div>

              <div style="margin-top: 16px">
                <button class="btn btn-primary">Save Settings</button>
              </div>
            </form>
          </div>
        </section>
      </section>
    </main>
  </body>
</html>
