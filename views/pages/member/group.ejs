<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — Group Information</title>
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="/css/member.css" />
  </head>
  <body>
    <main class="container dashboard-layout">
      <%- include('../partials/membersidebar') %>

      <section class="dashboard-content">
        <div class="page-header">
          <div>
            <h1 class="h1">Group Information</h1>
            <p class="lead">Learn about your group, members, and policies</p>
          </div>
        </div>

        <!-- GROUP OVERVIEW -->
        <section class="dashboard-section">
          <h2 class="h2">Group Overview</h2>
          <div class="card group-overview">
            <div class="group-header">
              <h3>-</h3>
              <p class="small">No group description available.</p>
            </div>

            <div class="group-stats">
              <div class="stat">
                <strong>Total Members:</strong>
                <p>-</p>
              </div>
              <div class="stat">
                <strong>Founded:</strong>
                <p>-</p>
              </div>
              <div class="stat">
                <strong>Meeting Frequency:</strong>
                <p>-</p>
              </div>
              <div class="stat">
                <strong>Group Type:</strong>
                <p>-</p>
              </div>
            </div>

            <div
              style="
                margin-top: 20px;
                padding-top: 20px;
                border-top: 1px solid #e0e0e0;
              "
            >
              <h4>Group Mission</h4>
              <p>No mission statement available.</p>
            </div>
          </div>
        </section>

        <!-- GROUP FINANCIAL SUMMARY -->
        <section class="dashboard-section">
          <h2 class="h2">Financial Summary</h2>
          <div class="metrics-grid">
            <div class="metric-card">
              <div class="metric-label">Total Savings</div>
              <div class="metric-value value-success">-</div>
              <div class="small" style="margin-top: 8px">No data yet</div>
            </div>

            <div class="metric-card">
              <div class="metric-label">Total Loans Disbursed</div>
              <div class="metric-value value-info">-</div>
              <div class="small" style="margin-top: 8px">No data yet</div>
            </div>

            <div class="metric-card">
              <div class="metric-label">Active Loans</div>
              <div class="metric-value value-warning">-</div>
              <div class="small" style="margin-top: 8px">No data yet</div>
            </div>

            <div class="metric-card">
              <div class="metric-label">Interest Earned</div>
              <div class="metric-value value-success">-</div>
              <div class="small" style="margin-top: 8px">No data yet</div>
            </div>
          </div>
        </section>

        <!-- MEMBER DIRECTORY -->
        <section class="dashboard-section">
          <h2 class="h2">Member Directory</h2>
          <div class="card">
            <div style="margin-bottom: 20px">
              <input
                type="text"
                placeholder="Search members by name, phone..."
                class="search-input"
                style="
                  width: 100%;
                  padding: 10px;
                  border: 1px solid #e0e0e0;
                  border-radius: 4px;
                "
              />
            </div>

            <table class="table">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Phone</th>
                  <th>Email</th>
                  <th>Role</th>
                  <th>Member Since</th>
                  <th>Contact</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td colspan="6">No members available.</td>
                </tr>
              </tbody>
            </table>
            <p class="small" style="margin-top: 15px">Showing 0 members.</p>
          </div>
        </section>

        <!-- GROUP BYLAWS & RULES -->
        <section class="dashboard-section">
          <h2 class="h2">Group Bylaws & Rules</h2>
          <div class="card">
            <div class="accordion">
              <p>No bylaws have been published yet.</p>
            </div>
          </div>
        </section>

        <!-- DOWNLOAD DOCUMENTS -->
        <section class="dashboard-section">
          <h2 class="h2">Important Documents</h2>
          <div class="card">
            <div class="document-list">
              <p>No documents available.</p>
            </div>
          </div>
        </section>

        <div style="margin-top: 30px; padding-bottom: 30px">
          <a href="/member/dashboard" class="btn btn-secondary"
            >Back to Dashboard</a
          >
        </div>
      </section>
    </main>

    <script>
      function toggleAccordion(header) {
        const content = header.nextElementSibling;
        const isOpen = content.style.display !== "none";

        // Close all other accordion items
        document.querySelectorAll(".accordion-content").forEach((item) => {
          item.style.display = "none";
        });
        document.querySelectorAll(".accordion-header span").forEach((span) => {
          span.textContent = "+";
        });

        // Toggle current item
        if (!isOpen) {
          content.style.display = "block";
          header.querySelector("span").textContent = "−";
        }
      }
    </script>
  </body>
</html>
