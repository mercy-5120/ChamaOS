<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — Treasurer Dashboard</title>
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="/css/treasurer.css" />
  </head>
  <body>
    <main class="container dashboard-layout">
      <%- include('../partials/treasurersidebar') %>

      <section class="dashboard-content">
        <% const money = (value) => Number(value || 0).toLocaleString(); %>
        <% const trendLabel = (trend) => {
             if (!trend || trend.direction === 'flat') return 'No change vs last month';
             const movement = trend.direction === 'up' ? 'Up' : 'Down';
             return `${movement} ${trend.pct}% vs last month`;
           }; %>
        <div class="page-header">
          <div>
            <h1 class="h1">Treasurer Dashboard</h1>
            <p class="lead">
              Group cash position, loans, approvals and recent activity.
            </p>
            <p class="treasurer-asof">As of <%= asOfDateTime %></p>
          </div>
        </div>

        <section class="dashboard-section">
          <h2 class="h2">Overview</h2>
          <div class="metrics-grid">
            <div class="metric-card">
              <div class="metric-label">Total Contributions</div>
              <div class="metric-value value-success">KES <%= money(dashboard.totalContributions) %></div>
              <div class="metric-trend trend-<%= trends.totalContributions.direction %>"><%= trendLabel(trends.totalContributions) %></div>
            </div>
            <div class="metric-card">
              <div class="metric-label">Available Cash</div>
              <div class="metric-value value-deep">KES <%= money(dashboard.availableCash) %></div>
              <div class="metric-trend trend-<%= trends.availableCash.direction %>"><%= trendLabel(trends.availableCash) %></div>
            </div>
            <div class="metric-card">
              <div class="metric-label">Outstanding Loans</div>
              <div class="metric-value value-warning">KES <%= money(dashboard.outstandingLoans) %></div>
              <div class="metric-trend trend-<%= trends.outstandingLoans.direction %>"><%= trendLabel(trends.outstandingLoans) %></div>
            </div>
            <div class="metric-card">
              <div class="metric-label">Pending Approvals</div>
              <div class="metric-value value-info"><%= dashboard.pendingApprovals %></div>
              <div class="metric-trend trend-<%= trends.pendingApprovals.direction %>"><%= trendLabel(trends.pendingApprovals) %></div>
            </div>
          </div>
        </section>

        <section class="dashboard-section">
          <h2 class="h2">Recent Transactions</h2>
          <div class="card">
            <table class="table">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Member</th>
                  <th>Amount</th>
                  <th>Method</th>
                  <th>Reference</th>
                </tr>
              </thead>
              <tbody>
                <% if (recentTransactions && recentTransactions.length > 0) { %>
                  <% recentTransactions.forEach((tx) => { %>
                    <tr>
                      <td><%= tx.transaction_date %></td>
                      <td><%= tx.member_name %></td>
                      <td>KES <%= money(tx.amount) %></td>
                      <td style="text-transform: capitalize;"><%= tx.method || '-' %></td>
                      <td><%= tx.reference %></td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="5">No recent transactions available.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </section>

        <div style="margin-top: 30px">
          <a href="/treasurer/contributions" class="btn btn-secondary"
            >Manage Contributions</a
          >
          <a href="/treasurer/loans" class="btn btn-secondary">Manage Loans</a>
        </div>
      </section>
    </main>
  </body>
</html>
