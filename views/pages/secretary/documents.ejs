<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — Document Management</title>
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="/css/secretary.css" />
  </head>
  <body>
    <main class="container dashboard-layout">
      <%- include('../partials/secretarysidebar') %>

      <section class="dashboard-content">
        <div class="page-header">
          <div>
            <h1 class="h1">Document Management</h1>
            <p class="lead">
              Upload, categorize, and manage group documents with version
              control.
            </p>
          </div>
        </div>

        <% if (success) { %>
          <div class="alert alert-success"><%= success %></div>
        <% } %>
        <% if (error) { %>
          <div class="alert alert-error"><%= error %></div>
        <% } %>

        <!-- Upload Documents -->
        <section class="dashboard-section">
          <h2 class="h2">Upload Group Documents</h2>
          <div class="card form-card">
            <form method="POST" action="/secretary/upload-document" enctype="multipart/form-data" class="form-group">
              <div class="form-row">
                <div class="form-col">
                  <label for="doc-name" class="form-label">Document Name *</label>
                  <input
                    type="text"
                    id="doc-name"
                    name="doc_title"
                    class="form-control"
                    placeholder="e.g., Annual Financial Report 2025"
                    required
                  />
                </div>
                <div class="form-col">
                  <label for="doc-type" class="form-label">Document Type *</label>
                  <select id="doc-type" name="doc_type" class="form-control" required>
                    <option value="">-- Select type --</option>
                    <option value="constitution">Constitution</option>
                    <option value="bylaws">Bylaws</option>
                    <option value="financial">Financial</option>
                    <option value="governance">Governance</option>
                    <option value="welfare">Welfare</option>
                    <option value="policies">Policies</option>
                    <option value="other">Other</option>
                  </select>
                </div>
              </div>

              <div class="form-row">
                <div class="form-col full-width">
                  <label for="doc-file" class="form-label">Upload File *</label>
                  <div class="file-upload">
                    <input
                      type="file"
                      id="doc-file"
                      name="doc_file"
                      class="form-control"
                      required
                    />
                    <p class="text-muted text-sm">
                      Supported: PDF, Word, Excel, PowerPoint
                    </p>
                  </div>
                </div>
              </div>

              <button type="submit" class="btn btn-primary">Upload Document</button>
            </form>
          </div>
        </section>

        <!-- Document Search & Filter -->
        <section class="dashboard-section">
          <h2 class="h2">Document Repository</h2>
          <div class="card">
            <% if (documents && documents.length > 0) { %>
              <table class="table">
                <thead>
                  <tr>
                    <th>Title</th>
                    <th>Type</th>
                    <th>File</th>
                    <th>Uploaded At</th>
                    <th>Action</th>
                  </tr>
                </thead>
                <tbody>
                  <% documents.forEach(function(doc) { %>
                    <tr>
                      <td><%= doc.title %></td>
                      <td style="text-transform:capitalize;"><%= doc.document_type %></td>
                      <td><%= doc.file_name %></td>
                      <td><%= doc.uploaded_at %></td>
                      <td>
                        <a href="<%= doc.file_path %>" class="btn btn-secondary btn-sm" target="_blank" rel="noopener">Download</a>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            <% } else { %>
              <div class="documents-list">
                <p>No documents available.</p>
              </div>
            <% } %>
          </div>
        </section>


      </section>
    </main>
  </body>
</html>
