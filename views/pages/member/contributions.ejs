<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — My Contributions</title>
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="/css/member.css" />
  </head>
  <body>
    <main class="container dashboard-layout">
      <%- include('../partials/membersidebar') %>

      <section class="dashboard-content">
        <div class="page-header">
          <div>
            <h1 class="h1">My Contributions</h1>
            <p class="lead">View your contribution history and schedule</p>
          </div>
        </div>

        <!-- CONTRIBUTION STATISTICS -->
        <section class="dashboard-section">
          <h2 class="h2">Contribution Statistics</h2>
          <div class="metrics-grid">
            <div class="metric-card">
              <div class="metric-label">Total Paid</div>
              <div class="metric-value value-success">
                KES <%= Number(contributionStats?.totalPaid || 0).toLocaleString() %>
              </div>
              <div class="small" style="margin-top: 8px">
                <%= contributionStats?.paymentCount || 0 %> completed payments
              </div>
            </div>

            <div class="metric-card">
              <div class="metric-label">Average Contribution</div>
              <div class="metric-value value-deep">
                KES <%= Number(contributionStats?.averageContribution || 0).toLocaleString() %>
              </div>
              <div class="small" style="margin-top: 8px">Based on completed payments</div>
            </div>

            <div class="metric-card">
              <div class="metric-label">Payment Status</div>
              <div class="metric-value value-info"><%= contributionStats?.paymentStatus || 'No payments yet' %></div>
              <div class="small" style="margin-top: 8px">Live from recorded transactions</div>
            </div>
          </div>
        </section>

        <!-- CONTRIBUTION HISTORY -->
        <section class="dashboard-section">
          <h2 class="h2">Contribution History</h2>
          <div class="card">
            <table class="table">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Amount</th>
                  <th>Payment Method</th>
                  <th>Status</th>
                  <th>Reference</th>
                </tr>
              </thead>
              <tbody>
                <% if (contributions && contributions.length > 0) { %>
                  <% contributions.forEach(function(tx) { %>
                    <tr>
                      <td><%= tx.contribution_date %></td>
                      <td>KES <%= Number(tx.amount).toLocaleString() %></td>
                      <td><%= (tx.description || '').replace('Payment Method: ', '') || '-' %></td>
                      <td><%= tx.status %></td>
                      <td>TX-<%= tx.transaction_id %></td>
                    </tr>
                  <% }); %>
                <% } else { %>
                  <tr>
                    <td colspan="5">No contribution records available.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </section>

        <!-- CONTRIBUTION SCHEDULE -->
        <section class="dashboard-section">
          <h2 class="h2">Contribution Schedule</h2>
          <div class="card">
            <div style="margin-bottom: 20px">
              <h4>Expected vs Actual Contributions</h4>
            </div>
            <table class="table">
              <thead>
                <tr>
                  <th>Month</th>
                  <th>Expected Amount</th>
                  <th>Actual Amount</th>
                  <th>Status</th>
                  <th>Due Date</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Current Cycle</td>
                  <td>KES <%= Number(contributionPlan?.contribution_amount || 0).toLocaleString() %></td>
                  <td>KES <%= Number(contributionStats?.totalPaid || 0).toLocaleString() %></td>
                  <td><%= (contributionStats?.paymentCount || 0) > 0 ? 'Partially/Fully Paid' : 'Pending' %></td>
                  <td><%= contributionPlan?.nextDueDate || '-' %> (5th)</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <!-- PAYMENT REMINDERS -->
        <section class="dashboard-section">
          <h2 class="h2">Payment Reminders</h2>
          <div class="card reminder-box">
            <div class="reminder-alert reminder-alert-warning">
              <strong>⏰ Upcoming Payment</strong>
              <p>
                Your next contribution due date is
                <strong><%= contributionPlan?.nextDueDate || '-' %></strong>.
              </p>
              <p>
                Monthly contribution target: KES
                <strong><%= Number(contributionPlan?.contribution_amount || 0).toLocaleString() %></strong>.
              </p>
            </div>

            <div style="margin-top: 20px">
              <h4>Payment Methods</h4>
              <ul style="list-style: none; padding: 0">
                <li style="margin-bottom: 10px">
                  No payment methods configured.
                </li>
              </ul>
            </div>

            <div style="margin-top: 20px">
              <label style="display: flex; align-items: center; gap: 10px">
                <input type="checkbox" /> Enable payment reminders via SMS
              </label>
              <label
                style="
                  display: flex;
                  align-items: center;
                  gap: 10px;
                  margin-top: 10px;
                "
              >
                <input type="checkbox" checked /> Enable payment reminders via
                Email
              </label>
            </div>

            <div style="margin-top: 20px">
              <button class="btn btn-primary">Save Preferences</button>
            </div>
          </div>
        </section>

        <div style="margin-top: 30px; padding-bottom: 30px">
          <a href="/member/dashboard" class="btn btn-secondary"
            >Back to Dashboard</a
          >
        </div>
      </section>
    </main>
  </body>
</html>
