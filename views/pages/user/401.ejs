    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — Unauthorized</title>
    <link rel="stylesheet" href="/css/app.css" />
    <style></style>
  </head>
  <body>
      <%- include('../partials/header') %>

    <main class="container">
