<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — Chairperson Welfare</title>
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="/css/chairperson.css" />
  </head>
  <body>
    <main class="container dashboard-layout">
      <%- include('../partials/chairpersonsidebar') %>

      <section class="dashboard-content">
        <div class="page-header">
          <div>
            <h1 class="h1">Welfare Oversight</h1>
            <p class="lead">
              Review welfare requests, approvals, and welfare event planning.
            </p>
          </div>
        </div>

        <% if (typeof success !== 'undefined' && success) { %>
          <div class="alert alert-success" style="color:#1e6b41;background:#e8f7ee;border:1px solid #2a9d62;border-radius:6px;padding:0.75rem 1rem;margin-bottom:1rem;">
            <%= success %>
          </div>
        <% } %>
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert-error" style="color:#c0392b;background:#fdecea;border:1px solid #e74c3c;border-radius:6px;padding:0.75rem 1rem;margin-bottom:1rem;">
            <%= error %>
          </div>
        <% } %>

        <section class="dashboard-section">
          <h2 class="h2">Pending Welfare Requests</h2>
          <div class="card">
            <table class="table">
              <thead>
                <tr>
                  <th>Member</th>
                  <th>Request Type</th>
                  <th>Amount</th>
                  <th>Date</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <% if (pendingRequests && pendingRequests.length > 0) { %>
                  <% pendingRequests.forEach(function(request) { %>
                    <tr>
                      <td><%= request.member_name %></td>
                      <td style="text-transform: capitalize;"><%= request.request_type %></td>
                      <td>KES <%= Number(request.requested_amount || 0).toLocaleString() %></td>
                      <td><%= request.requested_on %></td>
                      <td>
                        <div style="display:flex;gap:8px;flex-wrap:wrap;">
                          <form action="/chairperson/welfare/decision" method="POST" style="margin:0;">
                            <input type="hidden" name="request_id" value="<%= request.request_id %>" />
                            <input type="hidden" name="decision" value="approve" />
                            <button type="submit" class="btn btn-primary btn-sm">Approve</button>
                          </form>
                          <form action="/chairperson/welfare/decision" method="POST" style="margin:0;">
                            <input type="hidden" name="request_id" value="<%= request.request_id %>" />
                            <input type="hidden" name="decision" value="reject" />
                            <button type="submit" class="btn btn-secondary btn-sm">Reject</button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  <% }); %>
                <% } else { %>
                  <tr>
                    <td colspan="5">No pending welfare requests available.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </section>

        <section class="dashboard-section">
          <h2 class="h2">Welfare Fund Status</h2>
          <div class="metrics-grid">
            <div class="metric-card">
              <div class="metric-label">Current Welfare Balance</div>
              <div class="metric-value value-deep">KES <%= Number(welfareSummary?.currentBalance || 0).toLocaleString() %></div>
            </div>
            <div class="metric-card">
              <div class="metric-label">Disbursed This Quarter</div>
              <div class="metric-value value-warning">KES <%= Number(welfareSummary?.disbursedQuarter || 0).toLocaleString() %></div>
            </div>
            <div class="metric-card">
              <div class="metric-label">Open Requests</div>
              <div class="metric-value value-info"><%= Number(welfareSummary?.openRequests || 0) %></div>
            </div>
          </div>
        </section>

        <section class="dashboard-section">
          <h2 class="h2">Welfare Events</h2>
          <div class="card form-card">
            <form class="form-group">
              <div class="form-row">
                <div class="form-col">
                  <label class="form-label" for="event-name">Event Name</label>
                  <input
                    id="event-name"
                    class="form-control"
                    type="text"
                    placeholder="Enter event name"
                  />
                </div>
                <div class="form-col">
                  <label class="form-label" for="event-date">Date</label>
                  <input id="event-date" class="form-control" type="date" />
                </div>
              </div>
              <div class="form-row">
                <div class="form-col full-width">
                  <label class="form-label" for="event-notes">Notes</label>
                  <textarea
                    id="event-notes"
                    class="form-control"
                    rows="3"
                    placeholder="Event objective and plan..."
                  ></textarea>
                </div>
              </div>
              <button class="btn btn-primary" type="submit">
                Create Welfare Event
              </button>
            </form>
          </div>
        </section>
      </section>
    </main>
  </body>
</html>
