<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — Calendar</title>
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="/css/secretary.css" />
  </head>
  <body>
    <main class="container dashboard-layout">
      <%- include('../partials/secretarysidebar') %>

      <section class="dashboard-content">
        <div class="page-header">
          <div>
            <h1 class="h1">Group Calendar</h1>
            <p class="lead">
              View and schedule meetings, events, and important dates.
            </p>
          </div>
          <div>
            <button class="btn btn-primary" data-action="create-event">
              + Schedule Event
            </button>
          </div>
        </div>

        <!-- Schedule Events -->
        <section class="dashboard-section">
          <h2 class="h2">Schedule New Event</h2>
          <div class="card form-card">
            <form class="form-group">
              <div class="form-row">
                <div class="form-col">
                  <label for="event-title" class="form-label"
                    >Event Title *</label
                  >
                  <input
                    type="text"
                    id="event-title"
                    class="form-control"
                    placeholder="e.g., Monthly General Meeting"
                    required
                  />
                </div>
              </div>

              <div class="form-row">
                <div class="form-col">
                  <label for="event-type" class="form-label"
                    >Event Type *</label
                  >
                  <select id="event-type" class="form-control" required>
                    <option value="">-- Select type --</option>
                    <option value="meeting">Meeting</option>
                    <option value="welfare">Welfare Event</option>
                    <option value="investment">Investment Activity</option>
                    <option value="training">Training</option>
                    <option value="social">Social Event</option>
                    <option value="other">Other</option>
                  </select>
                </div>
                <div class="form-col">
                  <label for="event-date" class="form-label">Date *</label>
                  <input
                    type="date"
                    id="event-date"
                    class="form-control"
                    required
                  />
                </div>
              </div>

              <div class="form-row">
                <div class="form-col">
                  <label for="event-start" class="form-label"
                    >Start Time *</label
                  >
                  <input
                    type="time"
                    id="event-start"
                    class="form-control"
                    required
                  />
                </div>
                <div class="form-col">
                  <label for="event-end" class="form-label">End Time</label>
                  <input type="time" id="event-end" class="form-control" />
                </div>
              </div>

              <div class="form-row">
                <div class="form-col full-width">
                  <label for="event-location" class="form-label"
                    >Location/Venue *</label
                  >
                  <input
                    type="text"
                    id="event-location"
                    class="form-control"
                    placeholder="Community Hall / Office / Online"
                    required
                  />
                </div>
              </div>

              <div class="form-row">
                <div class="form-col full-width">
                  <label for="event-description" class="form-label"
                    >Description</label
                  >
                  <textarea
                    id="event-description"
                    class="form-control"
                    rows="3"
                    placeholder="Event details, agenda, or instructions..."
                  ></textarea>
                </div>
              </div>

              <div class="form-row">
                <div class="form-col">
                  <label for="event-notify" class="form-label"
                    >Send Notification</label
                  >
                  <select id="event-notify" class="form-control">
                    <option value="yes">Yes</option>
                    <option value="no">No</option>
                  </select>
                </div>
                <div class="form-col">
                  <label for="event-remind" class="form-label"
                    >Reminder (Days Before)</label
                  >
                  <input
                    type="number"
                    id="event-remind"
                    class="form-control"
                    value="1"
                    min="0"
                  />
                </div>
              </div>

              <button type="submit" class="btn btn-primary">
                Schedule Event
              </button>
            </form>
          </div>
        </section>

        <!-- Calendar View -->
        <section class="dashboard-section">
          <h2 class="h2">Calendar</h2>
          <div class="card">
            <div class="calendar-controls">
              <button class="btn btn-secondary btn-sm">← Previous</button>
              <span class="calendar-month">No month selected</span>
              <button class="btn btn-secondary btn-sm">Next →</button>
            </div>

            <div class="calendar-grid">
              <div class="calendar-header">
                <div class="day-header">Sun</div>
                <div class="day-header">Mon</div>
                <div class="day-header">Tue</div>
                <div class="day-header">Wed</div>
                <div class="day-header">Thu</div>
                <div class="day-header">Fri</div>
                <div class="day-header">Sat</div>
              </div>

              <div class="calendar-body">
                <p>No calendar entries available.</p>
              </div>
            </div>
          </div>
        </section>

        <!-- Upcoming Events -->
        <section class="dashboard-section">
          <h2 class="h2">Upcoming Events</h2>
          <div class="card">
            <div class="events-list">
              <p>No upcoming events available.</p>
            </div>
          </div>
        </section>

        <!-- Set Reminders for Important Dates -->
        <section class="dashboard-section">
          <h2 class="h2">Reminders for Important Dates</h2>
          <div class="card form-card">
            <form class="form-group">
              <div class="form-row">
                <div class="form-col">
                  <label for="reminder-type" class="form-label"
                    >Reminder Type *</label
                  >
                  <select id="reminder-type" class="form-control" required>
                    <option value="">-- Select type --</option>
                    <option value="birthday">Member Birthday</option>
                    <option value="anniversary">Membership Anniversary</option>
                    <option value="deadline">Important Deadline</option>
                    <option value="payment">Payment Due</option>
                    <option value="review">Policy Review</option>
                  </select>
                </div>
                <div class="form-col">
                  <label for="reminder-date" class="form-label">Date *</label>
                  <input
                    type="date"
                    id="reminder-date"
                    class="form-control"
                    required
                  />
                </div>
              </div>

              <div class="form-row">
                <div class="form-col">
                  <label for="reminder-notify-before" class="form-label"
                    >Notify Me (Days Before)</label
                  >
                  <input
                    type="number"
                    id="reminder-notify-before"
                    class="form-control"
                    value="3"
                    min="1"
                  />
                </div>
                <div class="form-col">
                  <label for="reminder-freq" class="form-label"
                    >Frequency</label
                  >
                  <select id="reminder-freq" class="form-control">
                    <option value="once">Once Only</option>
                    <option value="yearly">Yearly</option>
                    <option value="monthly">Monthly</option>
                  </select>
                </div>
              </div>

              <div class="form-row">
                <div class="form-col full-width">
                  <label for="reminder-description" class="form-label"
                    >Description</label
                  >
                  <textarea
                    id="reminder-description"
                    class="form-control"
                    rows="2"
                    placeholder="What should we remember?"
                  ></textarea>
                </div>
              </div>

              <button type="submit" class="btn btn-primary">
                Set Reminder
              </button>
            </form>
          </div>
        </section>

        <!-- Active Reminders -->
        <section class="dashboard-section">
          <h2 class="h2">Active Reminders</h2>
          <div class="card">
            <table class="table">
              <thead>
                <tr>
                  <th>Type</th>
                  <th>Description</th>
                  <th>Date</th>
                  <th>Notify Before</th>
                  <th>Frequency</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td colspan="6">No active reminders available.</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>
      </section>
    </main>
  </body>
</html>
