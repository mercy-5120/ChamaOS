<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — Chairperson Reports</title>
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="/css/chairperson.css" />
  </head>
  <body>
    <main class="container dashboard-layout">
      <%- include('../partials/chairpersonsidebar') %>

      <section class="dashboard-content">
        <div class="page-header">
          <div>
            <h1 class="h1">Executive Reports</h1>
            <p class="lead">
              Access strategic summaries, growth trends, and annual performance
              reports.
            </p>
          </div>
        </div>

        <section class="dashboard-section">
          <h2 class="h2">Executive Summary</h2>
          <div class="card">
            <div class="stats-grid">
              <div class="stat-box">
                <div class="stat-label">Member Growth (12 months)</div>
                <div class="stat-value">+18%</div>
              </div>
              <div class="stat-box">
                <div class="stat-label">Contribution Growth</div>
                <div class="stat-value">+24%</div>
              </div>
              <div class="stat-box">
                <div class="stat-label">Loan Repayment Rate</div>
                <div class="stat-value">92%</div>
              </div>
            </div>
          </div>
        </section>

        <section class="dashboard-section">
          <h2 class="h2">Available Reports</h2>
          <div class="card">
            <table class="table">
              <thead>
                <tr>
                  <th>Report</th>
                  <th>Period</th>
                  <th>Owner</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Annual Performance Report</td>
                  <td>2025</td>
                  <td>Chairperson Office</td>
                  <td><a href="#" class="link">Download PDF</a></td>
                </tr>
                <tr>
                  <td>Member Participation Report</td>
                  <td>Q1 2026</td>
                  <td>Secretary</td>
                  <td><a href="#" class="link">Open</a></td>
                </tr>
                <tr>
                  <td>Financial Snapshot</td>
                  <td>February 2026</td>
                  <td>Treasurer</td>
                  <td><a href="#" class="link">Open</a></td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <section class="dashboard-section">
          <h2 class="h2">AGM Preparation Notes</h2>
          <div class="card form-card">
            <form class="form-group">
              <div class="form-row">
                <div class="form-col full-width">
                  <label class="form-label" for="agm-notes">Notes</label>
                  <textarea
                    id="agm-notes"
                    class="form-control"
                    rows="6"
                    placeholder="Track AGM agenda, performance highlights, and decisions to present..."
                  ></textarea>
                </div>
              </div>
              <button class="btn btn-primary" type="submit">Save Notes</button>
            </form>
          </div>
        </section>
      </section>
    </main>
  </body>
</html>
