<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS - Password Recovery</title>
    <link rel="stylesheet" href="/css/app.css" />
  </head>
  <body>
    <%- include('../partials/header', { brandTagline: 'Community saving, together', navItems: [ { text: 'Home', href: '/' }, { text: 'Login', href: '/login' }, { text: 'Sign up', href: '/signup' } ] }) %>

    <main class="container">
      <section class="auth-wrap">
        <div class="card auth-card">
          <h3 class="h1">Password Recovery</h3>
          <p class="lead">
            Self-service password reset is not available yet.
          </p>

          <div class="alert" style="background:#fff4e5;color:#7c4a03;border:1px solid #f3d19c;border-radius:6px;padding:0.85rem 1rem;">
            Please contact your Chama chairperson or administrator for password assistance.
          </div>

          <div class="form-foot" style="margin-top:1rem;">
            <a href="/login" class="btn btn-primary">Back to Login</a>
          </div>
        </div>
      </section>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
