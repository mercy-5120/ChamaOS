<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ChamaOS — Services</title>
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
      main {
        background:
          radial-gradient(circle at 8% 10%, rgba(42, 111, 75, 0.18), transparent 32%),
          radial-gradient(circle at 92% 8%, rgba(244, 185, 66, 0.18), transparent 28%),
          linear-gradient(180deg, #f6fbf7 0%, #f4f7f3 100%);
      }

      .hero-with-bg {
        background-image: linear-gradient(180deg, rgba(5, 16, 33, 0.78), rgba(5, 16, 33, 0.24)), url("/images/ChamaOSLandingpage.jpg");
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        position: relative;
        width: 100%;
        min-height: 720px;
        overflow: hidden;
        box-shadow: 0 24px 40px rgba(9, 18, 28, 0.18);
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .hero-with-bg::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at top left, rgba(244, 185, 66, 0.24), transparent 18%),
                    radial-gradient(circle at top right, rgba(42, 111, 75, 0.18), transparent 22%),
                    linear-gradient(180deg, rgba(6, 24, 44, 0.64), rgba(6, 24, 44, 0.40));
        z-index: 1;
      }

      .container-overlay {
        position: relative;
        z-index: 2;
        max-width: 980px;
        margin: 0 auto;
      }

      .hero-content {
        max-width: 820px;
        padding: 100px 28px 96px;
        border-radius: 32px;
        background: rgba(6, 19, 34, 0.28);
        backdrop-filter: blur(18px);
        border: 1px solid rgba(255, 255, 255, 0.12);
        text-align: center;
        color: #fff;
      }

      .hero-content .h1 {
        font-size: clamp(2.8rem, 5vw, 4rem);
        line-height: 1.03;
        letter-spacing: -0.04em;
        margin-bottom: 22px;
        text-wrap: balance;
      }

      .hero-content .lead {
        color: rgba(255, 255, 255, 0.92);
        max-width: 720px;
        margin: 0 auto 30px;
        font-size: 1.12rem;
        line-height: 1.8;
      }

      .hero-ctas {
        display: flex;
        gap: 14px;
        justify-content: center;
        flex-wrap: wrap;
      }

      .hero-ctas .btn-primary {
        background: var(--warm-gold);
        color: #113338;
        box-shadow: 0 10px 22px rgba(244, 185, 66, 0.22);
      }

      .hero-ctas .btn-secondary {
        background: rgba(255, 255, 255, 0.14);
        color: #fff;
        border: 1px solid rgba(255, 255, 255, 0.22);
      }

      .hero-ctas .btn-secondary:hover {
        background: rgba(255, 255, 255, 0.22);
      }

      .hero-meta {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 10px;
        margin-top: 24px;
        color: rgba(255, 255, 255, 0.78);
        font-size: 0.95rem;
      }

      .hero-meta span {
        background: rgba(255, 255, 255, 0.12);
        padding: 10px 16px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.08);
      }

      .about-section,
      .features-grid,
      .contact-section,
      .cta-section {
        margin: 40px auto;
        max-width: 1200px;
        padding: 0 20px;
      }

      .about-content {
        display: grid;
        grid-template-columns: 360px 1fr;
        gap: 32px;
        align-items: start;
        background: rgba(255, 255, 255, 0.95);
        border-radius: 28px;
        border: 1px solid rgba(11, 79, 108, 0.08);
        border-top: 4px solid rgba(42, 111, 75, 0.22);
        padding: 36px;
        box-shadow: 0 24px 40px rgba(15, 34, 46, 0.08);
      }

      .about-image {
        width: 100%;
        height: 100%;
        max-height: 420px;
        object-fit: cover;
        border-radius: 24px;
      }

      .about-text {
        flex: 1;
      }

      .about-text p {
        line-height: 1.78;
        color: rgba(42, 64, 80, 0.92);
      }

      .values-content {
        max-width: 980px;
        margin: 0 auto;
        background: linear-gradient(180deg, #fff, #f6faf4);
        border-radius: 26px;
        border: 1px solid rgba(42, 111, 75, 0.14);
        border-top: 4px solid rgba(42, 111, 75, 0.22);
        padding: 32px;
        box-shadow: 0 20px 40px rgba(15, 34, 46, 0.08);
      }

      .values-content .h1 {
        color: var(--deep-teal);
      }

      .features-content {
        max-width: 1200px;
        margin: 0 auto;
        background: linear-gradient(180deg, #fff, #f6faf4);
        border-radius: 26px;
        border: 1px solid rgba(42, 111, 75, 0.14);
        border-top: 4px solid rgba(42, 111, 75, 0.22);
        padding: 32px;
        box-shadow: 0 20px 40px rgba(15, 34, 46, 0.08);
      }

      .get-involved {
        text-align: center;
        margin-top: 24px;
      }

      .btn-margin {
        margin-left: 10px;
      }

      .features-grid {
        margin-top: 48px;
      }

      .features-head {
        max-width: 760px;
        margin: 0 auto 18px;
        text-align: center;
      }

      .features-head .h1 {
        margin-bottom: 8px;
        color: var(--forest-green);
      }

      .features-head .small {
        color: rgba(11, 79, 108, 0.9);
      }

      .features-head .small {
        font-size: 15px;
        line-height: 1.65;
      }

      .features-container {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
      }

      .features-container .card {
        padding: 20px;
        border: 1px solid rgba(11, 79, 108, 0.08);
        box-shadow: 0 12px 24px rgba(15, 34, 46, 0.08);
        transition:
          transform 180ms ease,
          box-shadow 180ms ease,
          border-color 180ms ease;
      }

      .features-container .card:nth-child(3n + 1) {
        border-top: 3px solid var(--deep-teal);
      }

      .features-container .card:nth-child(3n + 2) {
        border-top: 3px solid var(--warm-gold);
      }

      .features-container .card:nth-child(3n + 3) {
        border-top: 3px solid var(--forest-green);
      }

      .features-container .card:hover {
        transform: translateY(-4px);
        box-shadow: 0 18px 30px rgba(15, 34, 46, 0.12);
        border-color: rgba(42, 111, 75, 0.38);
      }

      .feature-icon {
        width: 42px;
        height: 42px;
        object-fit: contain;
        margin-bottom: 12px;
      }

      .service-section {
        margin: 40px auto;
        max-width: 1200px;
        padding: 0 20px;
      }

      .service-section h2 {
        text-align: center;
      }

      .service-card {
        margin-top: 16px;
      }

      .cta-container {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 20px;
      }

      .cta-left {
        background: linear-gradient(135deg, rgba(244, 185, 66, 0.18), rgba(42, 111, 75, 0.12));
        border: none;
        border-radius: 28px;
        padding: 34px;
        box-shadow: 0 22px 44px rgba(15, 34, 46, 0.08);
      }

      .cta-side-card {
        margin-top: 15px;
      }

      .margin-top-15 {
        margin-top: 15px;
      }

      .margin-top-24 {
        margin-top: 24px;
      }

      .margin-top-32 {
        margin-top: 32px;
      }

      .text-center {
        text-align: center;
      }

      .cards-container {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 12px;
        margin-top: 20px;
      }

      .values-card {
        width: 100%;
        padding: 24px;
        border-radius: 24px;
        border: none;
        background: linear-gradient(180deg, #fff, #f5faf4);
        box-shadow: 0 18px 36px rgba(15, 34, 46, 0.06);
      }

      .values-card:nth-child(odd) {
        border-bottom: 4px solid rgba(42, 111, 75, 0.4);
      }

      .values-card:nth-child(even) {
        border-bottom: 4px solid rgba(244, 185, 66, 0.45);
      }

      .contact-wrapper {
        display: grid;
        grid-template-columns: 1.1fr 1fr;
        gap: 30px; 
      }

      .contact-section .card {
        border: 1px solid rgba(42, 111, 75, 0.18);
        box-shadow: 0 14px 28px rgba(15, 34, 46, 0.08);
      }

      .contact-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
        margin-top: 14px;
      }

      .contact-item {
        background: linear-gradient(180deg, rgba(42, 111, 75, 0.04), rgba(11, 79, 108, 0.08));
        border: 1px solid rgba(42, 111, 75, 0.22);
        border-radius: 10px;
        padding: 12px;
      }

      .contact-item .icon {
        width: 24px;
        height: 24px;
        object-fit: contain;
        margin-bottom: 8px;
      }

      .contact-item .small {
        margin-bottom: 4px;
      }

      .contact-item strong {
        color: var(--deep-teal);
      }

      .contact-form .form-grid {
        display: grid;
        gap: 10px;
      }

      .contact-form textarea {
        width: 100%;
        min-height: 120px;
        padding: 10px 12px;
        border-radius: 10px;
        border: 1px solid rgba(21, 32, 43, 0.08);
        background: linear-gradient(180deg, #fff, #fbfbfb);
        font-size: 14px;
        font-family: inherit;
      }

      .contact-form textarea:focus {
        outline: 3px solid rgba(11, 79, 108, 0.08);
      }

      @media (max-width: 1024px) {
        .cards-container {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .features-container {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .contact-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

      }

      @media (max-width: 900px) {
        .hero-with-bg {
          min-height: 620px;
          background-attachment: scroll;
        }

        .hero-content {
          padding: 84px 20px 72px;
        }

        .about-content {
          grid-template-columns: 1fr;
          padding: 20px;
        }

        .about-image {
          max-height: 320px;
        }

        .values-content {
          padding: 22px;
        }

        .features-content {
          padding: 22px;
        }

        .contact-wrapper,
        .cta-container {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 620px) {
        .cards-container,
        .features-container,
        .contact-grid {
          grid-template-columns: 1fr;
        }

        .btn-margin {
          margin-left: 0;
          margin-top: 10px;
        }

        .get-involved .btn {
          width: 100%;
          justify-content: center;
        }
      }
    </style>
  </head>
  <body>
    <%- include('../partials/header', { brandTagline: 'Community savings. Built together.' }) %>

    <main>
      <section class="card hero hero-with-bg">
        <div class="container-overlay">
          <div class="hero-content">
            <h1 class="h1">
              ChamaOS — community finance made simple
            </h1>
            <p class="lead">
              A warm, trustworthy platform for chamas to collect contributions,
              manage records and celebrate shared milestones — designed for
              groups that save together.
            </p>
            <div class="hero-ctas">
              <a class="btn btn-primary" href="/signup">Get started — create a chama</a>
              <a class="btn btn-secondary" href="/login">Sign in</a>
            </div>
            <div class="hero-meta">
              <span>Track contributions</span>
              <span>Plan meetings</span>
              <span>Secure documents</span>
            </div>
          </div>
        </div>
      </section>

    <section class="about-section" id="about">
  <div class="about-content">
    <img src="/images/about.png" alt="A logo of a person" class="about-image">
    <div class="about-text"> <!-- New wrapper for all the text -->
      <h2 class="h1">About ChamaOS</h2>
      <p>
        ChamaOS empowers communities to save together with confidence. We believe that when groups 
        have the right tools, transparency, and trust, they can achieve remarkable financial goals. 
        Our platform makes it easy for chamas to manage contributions, track progress, and celebrate 
        shared milestones.
      </p>
      <p class="margin-top-15">
        Chamas have been a cornerstone of community finance in East Africa for generations. Millions 
        of people depend on these informal savings groups to build wealth, manage emergencies, and 
        invest in their futures. Yet many chamas still rely on manual record-keeping, phone calls, 
        and spreadsheets, making it easy for misunderstandings and errors to damage trust.
      </p>
      <p class="margin-top-15">
        ChamaOS was born from a simple idea: what if we gave chamas the tools that were previously 
        only available to formal institutions? Clear records, automated reminders, secure access 
        controls, and transparent financial tracking. We started building ChamaOS to bring modern 
        financial technology to the communities that matter most.
      </p>
    </div>
  </div>
</section>
      <section class="about-section" style="margin-top: 24px; padding: 20px;">
        <div class="values-content">
          <h1 class="h1">Our Values</h1>

          <div class="cards-container">
          <div class="card values-card">
            <h3 class="h3">🤝 Community First</h3>
            <p>We design every feature with chama members in mind. Our success is measured by theirs.</p>
          </div>
          
          <div class="card values-card">
            <h3 class="h3">🔓 Transparency</h3>
            <p>Financial clarity builds trust. We make it easy for groups to see and share what matters most.</p>
          </div>
          
          <div class="card values-card">
            <h3 class="h3">🛡️ Security</h3>
            <p>Your data is safe with us. We use industry-standard encryption and access controls.</p>
          </div>
          
          <div class="card values-card">
            <h3 class="h3">⚡ Simple</h3>
            <p>Financial tools should be easy to use, not complicated. We believe in elegant simplicity.</p>
          </div>
          </div>

          <h1 class="h1 margin-top-24">Get Involved</h1>
          
          <p>
            Whether you're the treasurer of a chama, a member looking for transparency, or a supporter 
            of community finance, there's a place for you in our community. Join ChamaOS today and help 
            us build the future of community savings.
          </p>
          
          <div class="get-involved">
            <a class="btn btn-primary" href="/signup">Create a chama now</a>
            <a class="btn btn-secondary btn-margin" href="/login">Sign in</a>
          </div>
        </div>
      </section>

      <section class="features-grid" id="features">
        <div class="features-content">
          <div class="features-head">
            <h2 class="h1">Features</h2>
            <p class="small">
              Everything your chama needs to plan, save, track, and grow together
              in one simple workspace.
            </p>
          </div>
          <div class="features-container">
            <div class="card">
              <img src="/images/groups.png" alt="Group management" class="feature-icon" />
              <div class="small">Group management</div>
              <h3 class="h2">Create & manage chamas</h3>
              <p class="small">
                Define groups, roles and contribution schedules with simple controls
                and clear permissions.
              </p>
            </div>

            <div class="card">
              <img src="/images/signing-a-document.png" alt="Contribution tracking" class="feature-icon" />
              <div class="small">Contribution tracking</div>
              <h3 class="h2">Records & reminders</h3>
              <p class="small">
                Automatic contribution tracking, reminders and receipts — all
                exportable for audits and transparency.
              </p>
            </div>

            <div class="card">
              <img src="/images/goal.png" alt="Milestones" class="feature-icon" />
              <div class="small">Milestones</div>
              <h3 class="h2">Celebrate progress</h3>
              <p class="small">
                Track goals, schedule payouts and reward members when the group
                reaches financial milestones.
              </p>
            </div>

            <div class="card">
              <img src="/images/lock.png" alt="Security" class="feature-icon" />
              <div class="small">Security</div>
              <h3 class="h2">Safe & auditable</h3>
              <p class="small">
                Role-based access, clear audit logs and exportable reports keep
                funds and relationships secure.
              </p>
            </div>

            <div class="card">
              <img src="/images/bargraph.png" alt="Insights" class="feature-icon" />
              <div class="small">Insights</div>
              <h3 class="h2">Simple analytics</h3>
              <p class="small">
                Clear dashboards and quick reports to help chamas understand growth
                and plan their next steps.
              </p>
            </div>

            <div class="card">
              <img src="/images/handshake.png" alt="Community" class="feature-icon" />
              <div class="small">Community</div>
              <h3 class="h2">Connect & grow</h3>
              <p class="small">
                Forums, events and shared milestones help groups learn from one
                another and strengthen trust.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section class="contact-section" id="contact">
        <div class="contact-wrapper">
          <div class="card">
            <h2 class="h1">Contact Us</h2>
            <p class="small">
              We are here to help your chama get set up, stay organized, and
              grow with confidence.
            </p>

            <div class="contact-grid">
              <div class="contact-item">
                <img src="/images/email.png" alt="Email icon" class="icon" />
                <div class="small">Email</div>
                <strong>support@chamaos.com</strong>
              </div>
              <div class="contact-item">
                <img src="/images/phone.png" alt="Phone icon" class="icon" />
                <div class="small">Phone</div>
                <strong>+254 700 000 000</strong>
              </div>
              <div class="contact-item">
                <img src="/images/whatsapp.png" alt="WhatsApp icon" class="icon" />
                <div class="small">WhatsApp</div>
                <strong>+254 700 000 000</strong>
              </div>
            </div>
          </div>

          <div class="card contact-form">
            <h3 class="h2">Send us a message</h3>
            <div id="contact-status-message" style="display: none; margin-bottom: 15px; padding: 12px 16px; border-radius: 4px;"></div>
            <form id="contact-form" class="form-grid">
              <div>
                <label for="contact_name">Full name</label>
                <input id="contact_name" name="contact_name" type="text" placeholder="Your name" required />
              </div>
              <div>
                <label for="contact_email">Email address</label>
                <input id="contact_email" name="contact_email" type="email" placeholder="you@example.com" required />
              </div>
              <div>
                <label for="contact_message">Message</label>
                <textarea id="contact_message" name="contact_message" placeholder="Tell us how we can help..." required></textarea>
              </div>
              <div>
                <button class="btn btn-primary" type="submit">Send Message</button>
              </div>
            </form>
          </div>
        </div>
      </section>

     
      <section class="cta-section">
        <div class="cta-container">
          <div class="card cta-left">
            <h3 class="h2">Ready to start?</h3>
            <p class="small">
              Join ChamaOS today and bring your group's savings to life. Create a
              chama in under a minute.
            </p>
            <div class="cta-action">
              <a class="btn btn-primary" href="/signup">Create a chama now</a>
            </div>
          </div>

          <div>
            <div class="card small">
              Have questions? <a class="link-muted" href="#contact">Contact support</a>
            </div>
            <div class="card small cta-side-card">
              <a class="link-muted" href="/about">Learn more about us</a>
            </div>
          </div>
        </div>
      </section>

      <!-- Footer -->
      <%- include('../partials/footer') %>
    </main>

    <script>
      document.getElementById('contact-form').addEventListener('submit', async (e) => {
        e.preventDefault();

        const formData = {
          contact_name: document.getElementById('contact_name').value.trim(),
          contact_email: document.getElementById('contact_email').value.trim(),
          contact_message: document.getElementById('contact_message').value.trim(),
        };

        const statusDiv = document.getElementById('contact-status-message');

        try {
          const response = await fetch('/contact', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(formData),
          });

          const result = await response.json();

          statusDiv.style.display = 'block';

          if (response.ok && result.success) {
            statusDiv.style.backgroundColor = '#d4edda';
            statusDiv.style.color = '#155724';
            statusDiv.style.border = '1px solid #c3e6cb';
            statusDiv.textContent = result.message;
            document.getElementById('contact-form').reset();

            // Hide the message after 5 seconds
            setTimeout(() => {
              statusDiv.style.display = 'none';
            }, 5000);
          } else {
            statusDiv.style.backgroundColor = '#f8d7da';
            statusDiv.style.color = '#721c24';
            statusDiv.style.border = '1px solid #f5c6cb';
            statusDiv.textContent = result.error || 'An error occurred. Please try again.';
          }
        } catch (error) {
          console.error('Error:', error);
          statusDiv.style.display = 'block';
          statusDiv.style.backgroundColor = '#f8d7da';
          statusDiv.style.color = '#721c24';
          statusDiv.style.border = '1px solid #f5c6cb';
          statusDiv.textContent = 'An error occurred. Please try again.';
        }
      });
    </script>
  </body>
</html>