<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>ChamaOS — Dashboard</title>
  <link rel="stylesheet" href="/css/app.css">
</head>
<body>
  <%- include('../partials/header', { brandTagline: 'Admin dashboard', navItems: [ { text: 'Home', href: '/' }, { text: 'Logout', href: '/login' } ] }) %>

  <main class="container">
    <section class="card">
      <div class="page-header-row">
        <div>
          <h2 class="h1">Overview</h2>
          <p class="lead">Key metrics for community health and growth.</p>
        </div>
        <div class="actions">
          <a class="btn btn-primary" href="#">New chama</a>
          <a class="btn btn-ghost" href="#">Export</a>
        </div>
      </div>

      <div class="kpi-row kpi-spaced">
        <div class="kpi">
          <div class="label">Total users</div>
          <div class="value"><%= allUsers ? allUsers.length : 0 %></div>
        </div>
        <div class="kpi">
          <div class="label">Male</div>
          <div class="value success-number"><%= maleFemaleCount ? maleFemaleCount.male : 0 %></div>
        </div>
        <div class="kpi">
          <div class="label">Female</div>
          <div class="value value-lavender"><%= maleFemaleCount ? maleFemaleCount.female : 0 %></div>
        </div>
      </div>

      <div class="split-row">
        <div class="card col-1">
          <div class="panel-flex">
            <div>
              <div class="small">Member split</div>
              <canvas id="genderChart" width="300" height="200"></canvas>
            </div>
            <div class="text-right">
              <div class="small">Active chamas</div>
              <div class="active-value">6</div>
            </div>
          </div>
        </div>

        <div class="card col-2">
          <div class="panel-flex">
            <div>
              <div class="small">Latest members</div>
              <h3 class="h2">Recent signups</h3>
            </div>
            <div>
              <div class="badge badge-community">Community</div>
            </div>
          </div>

          <table class="table" aria-describedby="recent-members">
            <thead>
              <tr><th>Name</th><th>Email</th><th>Ward</th><th>Gender</th></tr>
            </thead>
            <tbody>
              <% if (allUsers && allUsers.length > 0) { %>
                <% for (let i = 0; i < Math.min(allUsers.length, 6); i++) { const u = allUsers[i]; %>
                  <tr>
                    <td><%= u.full_name || u.fullname || '—' %></td>
                    <td><%= u.email %></td>
                    <td><%= u.ward || u.location || '—' %></td>
                    <td><span class="badge <%= (u.gender==='male')? 'badge-success' : (u.gender==='female')? 'badge-community' : 'badge-alert' %>"><%= u.gender || '—' %></span></td>
                  </tr>
                <% } %>
              <% } else { %>
                <tr><td colspan="4">No members yet</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <%- include('../partials/footer') %>
  </main>

  <script id="server-data" type="application/json"><%- chartData || '{}' %></script>
  <script>
    try {
      const chartData = JSON.parse(document.getElementById('server-data').textContent || '{}');
      const finalChartData = (chartData && chartData.labels && chartData.labels.length) ? chartData : { labels: [], datasets: [] };
      const ctx = document.getElementById('genderChart').getContext('2d');
      new Chart(ctx, { type: 'doughnut', data: finalChartData, options: { plugins: { legend: { position: 'bottom' } } } });
    } catch(e) { console.warn('Chart render skipped', e); }
  </script>
</body>
</html>