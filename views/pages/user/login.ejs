<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — Login</title>
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style></style>
  </head>
  <body>
    <%- include('../partials/header', { brandTagline: 'Community saving, together', navItems: [ { text: 'Home', href: '/' }, { text: 'Sign up', href: '/signup' } ] }) %>

    <main class="container">
      <section class="auth-wrap">
        <div class="card auth-card">
          <div class="auth-logo-wrap">
            <a href="/" aria-label="Go to home page">
              <img src="/images/ChamaOSLogo.png" alt="ChamaOS logo" class="auth-logo" />
            </a>
          </div>
          <h3 class="h1">Welcome back</h3>
          <p class="lead">
            Log in to manage your chama, contributions and milestones.
          </p>

          <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-error" style="color:#c0392b;background:#fdecea;border:1px solid #e74c3c;border-radius:6px;padding:0.75rem 1rem;margin-bottom:1rem;">
              <%= error %>
            </div>
          <% } %>

          <form action="/auth" method="POST" autocomplete="on">
            <div class="form-grid">
              <div>
                <label for="chama_id">Chama ID *</label>
                <input id="chama_id" name="chama_id" type="number" required placeholder="e.g., 1" />
                <small class="muted-note">Your Chama ID is shown on the confirmation screen when a Chama is created.</small>
              </div>
              <div>
                <label for="email">Email *</label>
                <input id="email" name="email" type="email" required placeholder="e.g., jane@example.com" />
              </div>
              <div>
                <label for="password">Password *</label>
                <input id="password" name="password" type="password" required placeholder="Your password" />
              </div>
            </div>

            <div class="form-foot">
              <div class="helper">
                <a href="/forgot-password" class="link-muted">Forgot password?</a>
              </div>
              <button class="btn btn-primary" type="submit">Sign in</button>
            </div>
          </form>

          <div class="muted-note" style="margin-top:1rem;">
            Creating a new Chama?
            <a href="/signup" class="link-muted">Set one up</a>
          </div>
          <div class="muted-note">
            Have an invite code?
            <a href="/join" class="link-muted">Join a Chama</a>
          </div>
        </div>
      </section>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
