<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — Chairperson Governance</title>
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="/css/chairperson.css" />
  </head>
  <body>
    <main class="container dashboard-layout">
      <%- include('../partials/chairpersonsidebar') %>

      <section class="dashboard-content">
        <div class="page-header">
          <div>
            <h1 class="h1">Governance</h1>
            <p class="lead">
              Manage bylaws, committees, policies, and compliance tracking.
            </p>
          </div>
        </div>

        <section class="dashboard-section">
          <h2 class="h2">Constitution & Bylaws</h2>
          <div class="card form-card">
            <% if (success) { %>
              <div class="alert success-alert" style="margin-bottom: 12px"><%= success %></div>
            <% } %>
            <% if (error) { %>
              <div class="alert error-alert" style="margin-bottom: 12px"><%= error %></div>
            <% } %>

            <form
              class="form-group"
              method="POST"
              action="/chairperson/governance/documents"
              enctype="multipart/form-data"
            >
              <div class="form-row">
                <div class="form-col full-width">
                  <label class="form-label" for="title"
                    >Document Title</label
                  >
                  <input
                    id="title"
                    name="title"
                    class="form-control"
                    type="text"
                    placeholder="e.g. Chama Constitution 2026"
                    required
                  />
                </div>
              </div>

              <div class="form-row">
                <div class="form-col full-width">
                  <label class="form-label" for="document_type">Document Type</label>
                  <select id="document_type" name="document_type" class="form-control" required>
                    <option value="">Select type</option>
                    <option value="constitution">Constitution</option>
                    <option value="bylaws">Bylaws</option>
                  </select>
                </div>
              </div>

              <div class="form-row">
                <div class="form-col full-width">
                  <label class="form-label" for="governance_document"
                    >Upload File</label
                  >
                  <input
                    id="governance_document"
                    name="governance_document"
                    class="form-control"
                    type="file"
                    accept=".pdf,.doc,.docx,.txt"
                    required
                  />
                </div>
              </div>
              <button class="btn btn-primary" type="submit">Upload Document</button>
            </form>

            <div style="margin-top: 20px; border-top: 1px solid #e0e0e0; padding-top: 20px;">
              <h3 class="h3">Uploaded Governance Documents</h3>
              <table class="table" style="margin-top: 10px;">
                <thead>
                  <tr>
                    <th>Type</th>
                    <th>Title</th>
                    <th>File</th>
                    <th>Uploaded</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (governanceDocuments && governanceDocuments.length > 0) { %>
                    <% governanceDocuments.forEach(function(doc) { %>
                      <tr>
                        <td><%= doc.document_type === 'constitution' ? 'Constitution' : 'Bylaws' %></td>
                        <td><%= doc.title %></td>
                        <td><a href="<%= doc.file_path %>" target="_blank" rel="noopener">View Document</a></td>
                        <td><%= doc.uploaded_at %></td>
                      </tr>
                    <% }); %>
                  <% } else { %>
                    <tr>
                      <td colspan="4">No constitution or bylaws uploaded yet.</td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </section>

        <section class="dashboard-section">
          <h2 class="h2">Committee Management</h2>
          <div class="card">
            <table class="table">
              <thead>
                <tr>
                  <th>Committee</th>
                  <th>Lead</th>
                  <th>Members</th>
                  <th>Status</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td colspan="5">No committee records available.</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <section class="dashboard-section">
          <h2 class="h2">Policy Compliance</h2>
          <div class="card">
            <div class="stats-grid">
              <div class="stat-box">
                <div class="stat-label">Policy Adherence</div>
                <div class="stat-value">-</div>
              </div>
              <div class="stat-box">
                <div class="stat-label">Open Compliance Issues</div>
                <div class="stat-value">-</div>
              </div>
              <div class="stat-box">
                <div class="stat-label">Resolved This Month</div>
                <div class="stat-value">-</div>
              </div>
            </div>
          </div>
        </section>
      </section>
    </main>
  </body>
</html>
