<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — Loans</title>
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="/css/member.css" />
  </head>
  <body>
    <main class="container dashboard-layout">
      <%- include('../partials/membersidebar') %>

      <section class="dashboard-content">
        <div class="page-header">
          <div>
            <h1 class="h1">Loans</h1>
            <p class="lead">Apply for loans and track your repayments</p>
          </div>
          <div class="actions">
            <button class="btn btn-primary" onclick="toggleLoanForm()">
              Apply for New Loan
            </button>
          </div>
        </div>

        <% if (success) { %>
          <div class="alert alert-success"><%= success %></div>
        <% } %>
        <% if (error) { %>
          <div class="alert alert-error"><%= error %></div>
        <% } %>

        <!-- LOAN APPLICATION FORM -->
        <section
          class="dashboard-section"
          id="loan-form-section"
          style="display: none"
        >
          <h2 class="h2">Apply for a New Loan</h2>
          <div class="card">
            <form method="POST" action="/member/loans/apply">
              <div class="form-group">
                <label for="loan-amount">Loan Amount (KES)</label>
                <input
                  type="number"
                  id="loan-amount"
                  name="loan_amount"
                  placeholder="Enter amount"
                  min="1000"
                  max="100000"
                  required
                />
              </div>

              <div class="form-group">
                <label for="loan-reason">Reason for Loan</label>
                <select id="loan-reason" name="loan_reason" required>
                  <option value="">-- Select a reason --</option>
                  <option value="business">Business Investment</option>
                  <option value="education">Education</option>
                  <option value="health">Health/Medical</option>
                  <option value="property">Property/Housing</option>
                  <option value="emergency">Emergency</option>
                  <option value="other">Other</option>
                </select>
              </div>

              <div class="form-group">
                <label for="loan-reason-detail">Detailed Description</label>
                <textarea
                  id="loan-reason-detail"
                  name="loan_reason_detail"
                  placeholder="Provide more details about your loan request"
                  rows="4"
                ></textarea>
              </div>

              <div class="form-group">
                <label for="repayment-period">Repayment Period (months)</label>
                <select id="repayment-period" name="repayment_period" required>
                  <option value="">-- Select period --</option>
                  <option value="3">3 months</option>
                  <option value="6">6 months</option>
                  <option value="12">12 months</option>
                  <option value="24">24 months</option>
                </select>
              </div>

              <div
                style="
                  margin-top: 20px;
                  padding-top: 20px;
                  border-top: 1px solid #e0e0e0;
                "
              >
                <p>
                  <strong>Monthly Contribution Target:</strong>
                  KES
                  <%= Number(contributionDueSettings?.contribution_amount || 0).toLocaleString() %>
                </p>
                <p>
                  <strong>Next Contribution Due Date:</strong>
                  <%= contributionDueSettings?.nextDueDate || '-' %> (5th)
                </p>
                <p><strong>Interest Rate:</strong> Not set</p>
                <p><strong>Processing Fee:</strong> Not set</p>
              </div>

              <div style="margin-top: 20px">
                <button type="submit" class="btn btn-primary">
                  Submit Application
                </button>
                <button
                  type="button"
                  class="btn btn-secondary"
                  onclick="toggleLoanForm()"
                >
                  Cancel
                </button>
              </div>
            </form>
          </div>
        </section>

        <!-- ACTIVE LOANS -->
        <section class="dashboard-section">
          <h2 class="h2">Active Loans</h2>
          <div class="card">
            <table class="table">
              <thead>
                <tr>
                  <th>Loan ID</th>
                  <th>Amount</th>
                  <th>Balance</th>
                  <th>Due Date</th>
                  <th>Status</th>
                  <th>Approved On</th>
                </tr>
              </thead>
              <tbody>
                <% if (activeLoans && activeLoans.length > 0) { %>
                  <% activeLoans.forEach(function(loan) { %>
                    <tr>
                      <td><%= loan.loan_id %></td>
                      <td>KES <%= Number(loan.amount).toLocaleString() %></td>
                      <td>KES <%= Number(loan.remaining_balance).toLocaleString() %></td>
                      <td><%= loan.due_date %></td>
                      <td><span class="badge badge-success">Active</span></td>
                      <td><%= loan.approved_at || '-' %></td>
                    </tr>
                  <% }); %>
                <% } else { %>
                  <tr>
                    <td colspan="6">No active loans available.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </section>

        <!-- LOAN APPLICATIONS -->
        <section class="dashboard-section">
          <h2 class="h2">Loan Applications</h2>
          <div class="card">
            <table class="table">
              <thead>
                <tr>
                  <th>Application ID</th>
                  <th>Amount</th>
                  <th>Purpose</th>
                  <th>Applied Date</th>
                  <th>Status</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <% if (pendingApplications && pendingApplications.length > 0) { %>
                  <% pendingApplications.forEach(function(loan) { %>
                    <tr>
                      <td><%= loan.loan_id %></td>
                      <td>KES <%= Number(loan.amount).toLocaleString() %></td>
                      <td>Loan Request</td>
                      <td><%= loan.applied_date %></td>
                      <td><span class="badge badge-warning">Pending</span></td>
                      <td>Awaiting treasurer review</td>
                    </tr>
                  <% }); %>
                <% } else { %>
                  <tr>
                    <td colspan="6">No loan applications available.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </section>

        <!-- LOAN HISTORY -->
        <section class="dashboard-section">
          <h2 class="h2">Loan History</h2>
          <div class="card">
            <table class="table">
              <thead>
                <tr>
                  <th>Loan ID</th>
                  <th>Amount</th>
                  <th>Purpose</th>
                  <th>Issued Date</th>
                  <th>Repaid Date</th>
                  <th>Status</th>
                  <th>Decision Date</th>
                </tr>
              </thead>
              <tbody>
                <% if (loanHistory && loanHistory.length > 0) { %>
                  <% loanHistory.forEach(function(loan) { %>
                    <tr>
                      <td><%= loan.loan_id %></td>
                      <td>KES <%= Number(loan.amount).toLocaleString() %></td>
                      <td>Loan Request</td>
                      <td><%= loan.applied_date %></td>
                      <td><%= loan.status === 'completed' ? loan.due_date : '-' %></td>
                      <td><%= loan.status %></td>
                      <td><%= loan.rejected_at || loan.approved_at || '-' %></td>
                    </tr>
                  <% }); %>
                <% } else { %>
                  <tr>
                    <td colspan="7">No loan history available.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </section>

        <div style="margin-top: 30px; padding-bottom: 30px">
          <a href="/member/dashboard" class="btn btn-secondary"
            >Back to Dashboard</a
          >
        </div>
      </section>
    </main>

    <script>
      function toggleLoanForm() {
        const form = document.getElementById("loan-form-section");
        form.style.display = form.style.display === "none" ? "block" : "none";
      }

      function toggleRepaymentSchedule(loanId) {
        const schedule = document.getElementById(loanId + "-schedule");
        schedule.style.display =
          schedule.style.display === "none" ? "block" : "none";
      }
    </script>
  </body>
</html>
