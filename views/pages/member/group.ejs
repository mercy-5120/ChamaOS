<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — Group Information</title>
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="/css/member.css" />
  </head>
  <body>
    <main class="container dashboard-layout">
      <%- include('../partials/membersidebar') %>

      <section class="dashboard-content">
        <div class="page-header">
          <div>
            <h1 class="h1">Group Information</h1>
            <p class="lead">Learn about your group, members, and policies</p>
          </div>
        </div>

        <!-- GROUP OVERVIEW -->
        <section class="dashboard-section">
          <h2 class="h2">Group Overview</h2>
          <div class="card group-overview">
            <div class="group-header">
              <h3>Umoja Chama Group</h3>
              <p class="small">
                A community savings and lending group formed in 2020
              </p>
            </div>

            <div class="group-stats">
              <div class="stat">
                <strong>Total Members:</strong>
                <p>22</p>
              </div>
              <div class="stat">
                <strong>Founded:</strong>
                <p>January 2020</p>
              </div>
              <div class="stat">
                <strong>Meeting Frequency:</strong>
                <p>Monthly (Last Friday)</p>
              </div>
              <div class="stat">
                <strong>Group Type:</strong>
                <p>Savings & Lending</p>
              </div>
            </div>

            <div
              style="
                margin-top: 20px;
                padding-top: 20px;
                border-top: 1px solid #e0e0e0;
              "
            >
              <h4>Group Mission</h4>
              <p>
                To support our community members by fostering a culture of
                savings, mutual aid, and sustainable economic growth through
                collective financial management.
              </p>
            </div>
          </div>
        </section>

        <!-- GROUP FINANCIAL SUMMARY -->
        <section class="dashboard-section">
          <h2 class="h2">Financial Summary</h2>
          <div class="metrics-grid">
            <div class="metric-card">
              <div class="metric-label">Total Savings</div>
              <div class="metric-value value-success">KES 2,345,000</div>
              <div class="small" style="margin-top: 8px">
                Combined contributions
              </div>
            </div>

            <div class="metric-card">
              <div class="metric-label">Total Loans Disbursed</div>
              <div class="metric-value value-info">KES 1,500,000</div>
              <div class="small" style="margin-top: 8px">All time</div>
            </div>

            <div class="metric-card">
              <div class="metric-label">Active Loans</div>
              <div class="metric-value value-warning">KES 850,000</div>
              <div class="small" style="margin-top: 8px">6 members</div>
            </div>

            <div class="metric-card">
              <div class="metric-label">Interest Earned</div>
              <div class="metric-value value-success">KES 125,500</div>
              <div class="small" style="margin-top: 8px">This year</div>
            </div>
          </div>
        </section>

        <!-- MEMBER DIRECTORY -->
        <section class="dashboard-section">
          <h2 class="h2">Member Directory</h2>
          <div class="card">
            <div style="margin-bottom: 20px">
