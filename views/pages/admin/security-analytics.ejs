<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — Admin Security & Analytics</title>
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="/css/admin.css" />
  </head>
  <body>
    <main class="container dashboard-layout">
      <%- include('../partials/adminsidebar') %>

      <section class="dashboard-content">
        <div class="page-header">
          <div>
            <h1 class="h1">Security, Audit & Analytics</h1>
            <p class="lead">
              Monitor audit events, security posture, suspicious activity, and
              platform performance.
            </p>
          </div>
        </div>

        <section class="dashboard-section">
          <h2 class="h2">Security & Audit</h2>
          <div class="metrics-grid">
            <div class="metric-card">
              <div class="metric-label">Suspicious Events (24h)</div>
              <div class="metric-value value-warning">-</div>
            </div>
            <div class="metric-card">
              <div class="metric-label">Admin Access Changes</div>
              <div class="metric-value value-info">-</div>
            </div>
            <div class="metric-card">
              <div class="metric-label">2FA Coverage</div>
              <div class="metric-value value-success">-</div>
            </div>
          </div>

          <div class="card" style="margin-top: 16px">
            <table class="table">
              <thead>
                <tr>
                  <th>Time</th>
                  <th>Event</th>
                  <th>Actor</th>
                  <th>Severity</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td colspan="5">No security or audit events available.</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <section class="dashboard-section">
          <h2 class="h2">Analytics</h2>
          <div class="card">
            <table class="table">
              <thead>
                <tr>
                  <th>Metric</th>
                  <th>Current</th>
                  <th>Trend</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td colspan="4">No analytics data available.</td>
                </tr>
              </tbody>
            </table>
          </div>

          <div class="action-buttons" style="margin-top: 16px">
            <a href="#" class="btn btn-primary">Generate Performance Report</a>
            <a href="#" class="btn btn-secondary">Export Platform Data</a>
            <a href="#" class="btn btn-secondary">Export Compliance Data</a>
          </div>
        </section>
      </section>
    </main>
  </body>
</html>
