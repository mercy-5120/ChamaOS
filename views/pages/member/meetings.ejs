<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — Meetings</title>
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="/css/member.css" />
  </head>
  <body>
    <main class="container dashboard-layout">
      <%- include('../partials/membersidebar') %>

      <section class="dashboard-content">
        <div class="page-header">
          <div>
            <h1 class="h1">Meetings</h1>
            <p class="lead">View upcoming meetings and access past minutes</p>
          </div>
        </div>

        <!-- UPCOMING MEETINGS -->
        <section class="dashboard-section">
          <h2 class="h2">Upcoming Meetings</h2>
          <div class="card">
            <div class="meetings-list">
              <p>No upcoming meetings available.</p>
            </div>
          </div>
        </section>

        <!-- PAST MEETINGS & MINUTES -->
        <section class="dashboard-section">
          <h2 class="h2">Past Meeting Minutes</h2>
          <div class="card">
            <table class="table">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Meeting</th>
                  <th>Attendees</th>
                  <th>Minutes</th>
                  <th>Decisions</th>
                  <th>Download</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td colspan="6">No past meeting records available.</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <!-- ATTENDANCE HISTORY -->
        <section class="dashboard-section">
          <h2 class="h2">Your Attendance</h2>
          <div class="card">
            <div class="metrics-grid">
              <div class="metric-card">
                <div class="metric-label">Total Meetings</div>
                <div class="metric-value">-</div>
              </div>

              <div class="metric-card">
                <div class="metric-label">Attended</div>
                <div class="metric-value value-success">-</div>
              </div>

              <div class="metric-card">
                <div class="metric-label">Attendance Rate</div>
                <div class="metric-value value-success">-</div>
              </div>

              <div class="metric-card">
                <div class="metric-label">Absent</div>
                <div class="metric-value">-</div>
              </div>
            </div>

            <table class="table" style="margin-top: 25px">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Meeting</th>
                  <th>Your Status</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td colspan="3">No attendance records available.</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <div style="margin-top: 30px; padding-bottom: 30px">
          <a href="/member/dashboard" class="btn btn-secondary"
            >Back to Dashboard</a
          >
        </div>
      </section>
    </main>

    <script>
      function markAttendance(meetingId) {
        alert("Attendance marked for meeting: " + meetingId);
      }

      function viewMinutes(meetingId) {
        alert("Viewing minutes for meeting: " + meetingId);
      }

      function viewDecisions(meetingId) {
        alert("Viewing decisions for meeting: " + meetingId);
      }
    </script>
  </body>
</html>
