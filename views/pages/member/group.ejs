                    <a href="tel:+254700123456" class="link">Call</a> •
                    <a href="mailto:jane@example.com" class="link">Email</a>
                  </td>
                </tr>
                <tr>
                  <td>John Smith</td>
                  <td>+254 701 234 567</td>
                  <td>john@example.com</td>
                  <td><span class="badge badge-success">Treasurer</span></td>
                  <td>Mar 2020</td>
                  <td>
                    <a href="tel:+254701234567" class="link">Call</a> •
                    <a href="mailto:john@example.com" class="link">Email</a>
                  </td>
                </tr>
                <tr>
                  <td>Mary Johnson</td>
                  <td>+254 702 345 678</td>
                  <td>mary@example.com</td>
                  <td><span class="badge badge-info">Secretary</span></td>
                  <td>Feb 2020</td>
                  <td>
                    <a href="tel:+254702345678" class="link">Call</a> •
                    <a href="mailto:mary@example.com" class="link">Email</a>
                  </td>
                </tr>
                <tr>
                  <td>Peter Kipchoge</td>
                  <td>+254 703 456 789</td>
                  <td>peter@example.com</td>
                  <td>
                    <span class="badge badge-secondary">Regular Member</span>
                  </td>
                  <td>May 2020</td>
                  <td>
                    <a href="tel:+254703456789" class="link">Call</a> •
                    <a href="mailto:peter@example.com" class="link">Email</a>
