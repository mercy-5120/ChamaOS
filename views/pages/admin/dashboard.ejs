<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — System Admin Dashboard</title>
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="/css/admin.css" />
  </head>
  <body>
    <main class="container dashboard-layout">
      <%- include('../partials/adminsidebar') %>

      <section class="dashboard-content">
        <div class="page-header">
          <div>
            <h1 class="h1">System Admin Dashboard</h1>
            <p class="lead">
              Platform overview for operations, health, subscriptions, and
              growth.
            </p>
          </div>
        </div>

        <section class="dashboard-section">
          <h2 class="h2">Dashboard Overview</h2>
          <div class="metrics-grid">
            <div class="metric-card">
              <div class="metric-label">Total Groups</div>
              <div class="metric-value value-deep">156</div>
            </div>
            <div class="metric-card">
              <div class="metric-label">Total Users</div>
              <div class="metric-value value-success">3,240</div>
            </div>
            <div class="metric-card">
              <div class="metric-label">System Uptime</div>
              <div class="metric-value value-info">99.94%</div>
            </div>
            <div class="metric-card">
              <div class="metric-label">Monthly Revenue</div>
              <div class="metric-value value-warning">KES 124,500</div>
            </div>
          </div>
        </section>

        <section class="dashboard-section">
          <h2 class="h2">System Health & Recent Registrations</h2>
          <div class="card">
            <table class="table">
              <thead>
                <tr>
                  <th>Time</th>
                  <th>Event</th>
                  <th>Category</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>10:30 AM</td>
                  <td>New group registered: Baraka Chama</td>
                  <td>Registration</td>
                  <td><span class="badge badge-success">Completed</span></td>
                </tr>
                <tr>
                  <td>10:12 AM</td>
                  <td>Failed login attempts from one IP</td>
                  <td>Security</td>
                  <td><span class="badge badge-warning">Flagged</span></td>
                </tr>
                <tr>
                  <td>09:48 AM</td>
                  <td>Premium subscription payment received</td>
                  <td>Billing</td>
                  <td><span class="badge badge-success">Completed</span></td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <section class="dashboard-section">
          <h2 class="h2">Quick Access</h2>
          <div class="action-buttons">
            <a href="/admin/groups-users" class="btn btn-primary"
              >Manage Groups & Users</a
            >
            <a href="/admin/billing-config" class="btn btn-secondary"
              >Billing & Config</a
            >
            <a href="/admin/content-support" class="btn btn-secondary"
              >Content & Support</a
            >
            <a href="/admin/security-analytics" class="btn btn-secondary"
              >Security & Analytics</a
            >
          </div>
        </section>
      </section>
    </main>
  </body>
</html>
