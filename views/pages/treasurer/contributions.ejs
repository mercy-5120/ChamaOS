<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ChamaOS — Contributions (Treasurer)</title>
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="/css/treasurer.css" />
  </head>
  <body>
    <main class="container dashboard-layout">
      <%- include('../partials/treasurersidebar') %>

      <section class="dashboard-content">
        <div class="page-header">
          <div>
            <h1 class="h1">Contributions</h1>
            <p class="lead">Record and reconcile member contributions.</p>
          </div>
          <div class="actions">
            <a href="#record" class="btn btn-primary">Record Contribution</a>
            <a href="#import" class="btn btn-ghost">Import M-Pesa</a>
          </div>
        </div>

        <section class="dashboard-section">
          <h2 class="h2">Recent Contributions</h2>
          <div class="card">
            <table class="table">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Member</th>
                  <th>Amount</th>
                  <th>Method</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td colspan="5">No contributions available.</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <section class="dashboard-section">
          <h2 class="h2">Actions</h2>
          <div class="card">
            <form>
              <div class="form-grid">
                <div class="form-group">
                  <label for="member">Member</label>
                  <input id="member" placeholder="Search member" />
                </div>
                <div class="form-group">
                  <label for="amount">Amount (KES)</label>
                  <input id="amount" type="number" />
                </div>
                <div class="form-group">
                  <label for="method">Payment Method</label>
                  <select id="method">
                    <option>M-Pesa</option>
                    <option>Bank Transfer</option>
                    <option>Cash</option>
                  </select>
                </div>
                <div class="form-group">
                  <label for="date">Date</label>
                  <input id="date" type="date" />
                </div>
              </div>

              <div style="margin-top: 16px">
                <button class="btn btn-primary" type="submit">
                  Save Contribution
                </button>
              </div>
            </form>
          </div>
        </section>
      </section>
    </main>
  </body>
</html>
